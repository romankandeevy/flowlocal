// Окно программы: боковое меню плюс страницы. Вёрстка целиком здесь, данные -
// в settings_qt.Backend (контекстное свойство `B`), токены - в `T`.
//
// Сохранение сразу по изменению, кнопки «Применить» нет намеренно: лишний шаг,
// о котором легко забыть.
//
// ---- Почему окно одно ----
//
// Был день, когда его разделили надвое: «Главная», «История» и «Статистика»
// уехали в маленькое окно 460x560 рядом с треем, настройки остались здесь.
// Владелец запустил, увидел маленькое окно и сказал убрать его. Решение
// принято: программа одна, окно у неё одно, и возвращаться к двум не надо.
//
// Панель слева поэтому держит семь пунктов двумя группами: сверху своё
// (Главная, История, Статистика), ниже - настройки. Список ОДИН и плоский.
// Делить его на два массива с переключателем режима здесь уже пробовали, и
// стоило это пункта «Назад» - выхода, которого в обычном окне не бывает:
// человек нажимал «Настройки», панель под ним подменялась целиком, и вернуться
// он мог только по строке, придуманной ради этой подмены. Границу групп рисует
// пустота в 12 пикселей - не заголовок и не линия.
//
// «Заметки» - пункт панели, но отдельное ОКНО: не подсвечивается и не меняет
// win.page. Дверь ему нужна именно здесь - пока её не было, скретчпад можно
// было найти только в трее, и владелец его не нашёл.
//
// Дверей настроек четыре: Основное+Распознавание+Ввод слились в «Диктовку»,
// Словарь+Замены - в «Слова», плюс «Дополнительно» и «О программе». Отдельной
// страницы «Модели» нет: в каталоге осталось две модели, и обе живут одной
// строкой - экран под два варианта был бы лишней дверью.
//
// «Дополнительно» - не свалка, а список симптомов (docs/revision-2026-07-19.md,
// раздел 2). Туда уехало то, у чего правильное значение уже стоит, а трогают
// его в единственном случае: когда что-то пошло не так. Раз человек попал сюда,
// у него УЖЕ есть проблема - поэтому заголовки там не «как настроить», а «что
// чинить»: «Текст не появляется?» вместо «Как вставлять текст».
//
// Правило страниц: если возможность есть в коде, у неё есть место здесь.
// Настройка, которую видно только в config.json, для человека, которому
// программу отдали, не существует - сколько бы кода за ней ни стояло.

// ---- Почему тут импорт каталога, а не qmldir ----
//
// QML находит компоненты по СОСЕДСТВУ: пока всё лежало одной папкой, окна
// видели контролы даром. После деления на controls/ и windows/ соседства нет,
// и вернуть его можно двумя способами - положить в каждую папку qmldir или
// написать импорт каталога. Взят второй.
//
// qmldir в локально импортируемой папке становится ЕДИНСТВЕННЫМ списком её
// типов: заведёшь новый контрол и забудешь строку в qmldir - он не найдётся,
// причём молчаливо, на конкретной странице. Импорт каталога такого списка не
// держит и не устаревает. Цена - одна строка в каждом из пяти окон; внутри
// controls/ соседство осталось, там импорт не нужен вовсе.
import QtQuick
import "../controls"

Rectangle {
    id: win
    color: T.bg
    focus: true

    // Фактура из системы: точечная сетка и мягкий прожектор акцентом.
    // Плоская заливка - не то, чем Korti предлагает заполнять поверхность.
    Backdrop { anchors.fill: parent }

    // Зовёт Python при каждом открытии окна (settings_qt.SettingsWindow.open).
    //
    // Окно не пересоздаётся, а прячется и показывается - значит прокрутка
    // переживает закрытие. Человек долистал «Главную» до низа, закрыл, через
    // час открыл снова - и увидел середину страницы без приветствия и без
    // первой карточки. Выглядит это как обрезанное окно, а не как прокрутка:
    // строка начинается с середины фразы.
    //
    // Открытие - это всегда «покажи сначала». Точно так же ведёт себя переход
    // между страницами ниже, и по той же причине.
    function resetScroll() { scroll.contentY = 0 }

    // Открывается на «Главной»: окно открывают посмотреть, работает ли и что
    // надиктовано, а не настраивать. Настройки - вторая половина панели.
    property string page: "Главная"
    // Новая страница - с начала: прокрутка одной не должна доставаться другой.
    // И проявляется, а не возникает рывком, - см. pageIn у content.
    onPageChanged: { scroll.contentY = 0; pageIn.restart() }
    readonly property var pages: ["Главная", "История", "Статистика",
                                  "Диктовка", "Слова", "Дополнительно",
                                  "О программе"]
    // Сколько пунктов в первой группе. По этому числу панель ставит отбивку
    // перед настройками - одно место, где живёт граница, вместо второго
    // массива, который рано или поздно разъедется с первым.
    readonly property int ownPages: 3

    // Архив прежних версий (0.x) для выплывающей панели на «О программе».
    // Читаем один раз при сборке окна: файл на диске на ходу не меняется, а на
    // этот список смотрят и кнопка-открывашка, и сама панель. Пусто (нет файла
    // в сборке) - кнопки не будет, панель не открыть, и это законный вид.
    property var oldVersionsData: []
    property bool showOldVersions: false
    Component.onCompleted: oldVersionsData = B.oldVersions()

    // Одна строка под заголовком отвечает на «что мне это даст» - правило
    // голоса бренда. Страницы без записи («Главная» здоровается по имени и
    // говорит сама за себя, «О программе» - тоже) просто отсутствуют:
    // `subtitles[page] || ""` даёт пустую подпись, и строка прячется. Заводить
    // для них "" - два способа сказать одно.
    // Ключ - русское имя страницы (оно же идентификатор), значение переводится
    // при показе через L.t() там, где строка выводится.
    readonly property var subtitles: ({
        "История":        "Всё, что вы надиктовали. Можно найти и скопировать",
        "Статистика":     "Сколько вы наговорили и сколько времени это сберегло",
        "Диктовка":       "Сочетания, микрофон и то, как появляется текст",
        "Слова":          "Научите программу писать так, как нужно вам",
        "Дополнительно":  "Сюда заходят, когда что-то пошло не так"
    })

    // Сочетание для диктовки - одно на всё окно.
    //
    // Читаем при заходе на страницу, а не привязкой: B.get - это вызов, а не
    // свойство, и привязка к нему не обновится сама, когда сочетание сменят на
    // «Диктовке». Держим здесь, а не по копии на страницу: спрашивают его три
    // (на «Главной» - карточкой, на пустых «Истории» и «Статистике» -
    // приглашением начать), и три одинаковых чтения - это три места, где оно
    // однажды разъедется.
    property string hotkey: ""
    function reloadHotkey() {
        var hold = B.get("hotkey_hold");
        var toggle = B.get("hotkey_toggle");
        // Проверяем сырые значения, а не pretty(): у пустого сочетания
        // pretty() возвращает «не задано» - непустую строку, и условие на ней
        // всегда истинно. Ровно на этом карточка раньше писала «Зажмите не
        // задано и говорите».
        win.hotkey = (hold || toggle) ? B.pretty(hold || toggle) : "";
    }

    // Esc: сперва закрывает выплывающую панель прежних версий, если открыта;
    // иначе во время захвата отменяет захват, иначе закрывает окно.
    Keys.onEscapePressed: {
        if (win.showOldVersions)
            win.showOldVersions = false;
        else
            B.cancelCapture();
    }

    Connections {
        target: B
        function onFlashed(text, kind) {
            // Через словарь: подписи приходят из Python готовыми
            // строками, и до сих пор в английском интерфейсе они
            // оставались русскими. Незнакомая строка вернётся из t()
            // как есть - на составных с числами это и нужно.
            footer.text = L.t(text);
            footer.danger = kind === "danger";
            footer.color = kind === "danger" ? T.danger
                         : kind === "accent" ? T.accent : T.textMuted;
            flashTimer.restart();
        }
    }
    // Ошибку держим дольше остальных подписей: «сохранено» можно и пропустить,
    // а «не сохранилось» человек должен успеть прочитать и нажать журнал рядом.
    Timer {
        id: flashTimer
        interval: footer.danger ? 6000 : 2200
        onTriggered: { footer.text = ""; footer.danger = false }
    }

    Icons { id: ic }

    // Пункт панели, ведущий на страницу. Заведён отдельным типом, потому что
    // групп в меню две, а вид пункта - один: без него пришлось бы написать
    // делегата дважды и следить, чтобы обе копии не разъехались.
    //
    // Имя страницы служит и идентификатором (win.page === ...), поэтому
    // переводим только показ, а не сам массив.
    component PageNav: NavItem {
        property string pageName: ""
        label: L.t(pageName)
        icon: ic.forPage(pageName)
        active: win.page === pageName
        onClicked: win.page = pageName
    }

    // ---------- боковое меню ----------
    // Канон Korti (templates/app-shell): панель 240, отделена линией, вордмарк
    // со знаком, ниже - навигация с иконками.
    Item {
        id: side
        width: 240
        anchors { left: parent.left; top: parent.top; bottom: parent.bottom }

        // Линия-разделитель: в системе панель всегда отделена от содержимого.
        // Без неё окно разваливалось на два несвязанных поля.
        Rectangle {
            anchors { right: parent.right; top: parent.top; bottom: parent.bottom }
            width: 1
            color: T.border
        }

        Column {
            anchors { left: parent.left; right: parent.right; top: parent.top
                      leftMargin: 16; rightMargin: 16; topMargin: 16 }
            spacing: 4

            Wordmark {
                leftPadding: 8
                bottomPadding: 18
            }

            // Первая группа: своё. Главная, История, Статистика.
            Repeater {
                model: win.pages.slice(0, win.ownPages)
                PageNav { pageName: modelData }
            }

            // «Заметки» - отдельное ОКНО, а не страница, поэтому пункт не
            // подсвечивается и не меняет win.page. Стоит здесь, в первой
            // группе: это место, куда диктуют, а не то, что настраивают.
            //
            // Дверь ему нужна именно в панели: пока её не было, скретчпад
            // можно было найти только в трее, и владелец его не нашёл.
            // Возможность, которую не видно, всё равно что не сделана.
            NavItem {
                label: L.t("Заметки")
                icon: ic.forPage("Заметки")
                active: false
                onClicked: B.openNotes()
            }

            // Граница групп - пустота, а не линия и не второй заголовок.
            // Линия в панели уже есть (справа, вдоль всей высоты), и вторая
            // разрезала бы меню на два меню; заголовок вроде «НАСТРОЙКИ» -
            // это слово ради слова над четырьмя строками, которые и так
            // читаются как настройки.
            Item { width: 1; height: 12 }

            // Вторая группа: настройки.
            Repeater {
                model: win.pages.slice(win.ownPages)
                PageNav { pageName: modelData }
            }
        }

        // Низ панели: чем диктовать. Korti кладёт сюда карточку пользователя -
        // у нас пользователя нет, а вот сочетание человек ищет постоянно, и
        // это единственное место, где оно всегда на виду.
        //
        // Сюда же, над сочетаниями, - предложение обновиться. Панель видна с
        // любой страницы, поэтому новость доходит независимо от того, где
        // человек находится. Всплывающего окна нет намеренно - диктовка
        // работает поверх чужой работы, и выскакивать посреди неё с новостью о
        // версии значит мешать.
        Column {
            anchors { left: parent.left; right: parent.right; bottom: parent.bottom
                      leftMargin: 24; rightMargin: 16; bottomMargin: 16 }
            spacing: 4

            Item {
                id: upd
                property var info: B.pendingUpdate()
                readonly property bool has: info && info.version
                visible: has
                width: parent.width
                height: has ? updCol.implicitHeight + 20 : 0

                Column {
                    id: updCol
                    width: parent.width - 8
                    spacing: 4

                    Row {
                        spacing: 8
                        // Точка акцентом: в Korti синий - «особенное», и
                        // обновление ровно оно. Красный тут был бы враньём:
                        // ничего не сломалось.
                        Rectangle {
                            anchors.verticalCenter: parent.verticalCenter
                            width: 6; height: 6; radius: 3
                            color: T.accent
                        }
                        Text {
                            text: L.t("Версия ") + (upd.info.version || "")
                            font.family: T.sans; font.pixelSize: T.t2xs
                            font.weight: Font.DemiBold
                            color: T.text
                        }
                    }
                    Text {
                        width: updCol.width
                        wrapMode: Text.WordWrap
                        text: upd.info.title || ""
                        visible: text !== ""
                        maximumLineCount: 2
                        elide: Text.ElideRight
                        font.family: T.sans; font.pixelSize: T.t2xs
                        color: T.textMuted
                        lineHeight: 1.35
                    }
                    Text {
                        id: updLink
                        text: L.t("Обновить · ") + (upd.info.size_mb || 0) + L.t(" МБ")
                        font.family: T.sans; font.pixelSize: T.t2xs
                        font.weight: Font.Medium
                        font.underline: updHit.containsMouse
                        color: updHit.pressed ? T.accentHover : T.accent
                        Behavior on color { ColorAnimation { duration: T.durFast * 1000 } }
                        MouseArea {
                            id: updHit
                            anchors.fill: parent
                            anchors.margins: -4
                            hoverEnabled: true
                            cursorShape: Qt.PointingHandCursor
                            onClicked: B.applyUpdate()
                        }
                    }
                }
            }

            // Линия одна на двоих: блок обновления и сочетания разделяет та
            // же волосяная линия, что была тут всегда. Своя добавочная давала
            // на экране две подряд.
            Rectangle {
                width: parent.width - 8; height: 1; color: T.border
                anchors.horizontalCenter: parent.horizontalCenter
            }
            Item { width: 1; height: 9 }
            Text {
                text: L.t("ДИКТОВКА")
                font.family: T.sans; font.pixelSize: T.t2xs
                font.weight: Font.DemiBold; font.letterSpacing: 0.6
                color: T.textFaint
            }
            Text {
                width: parent.width
                text: {
                    var a = B.pretty(B.get("hotkey_hold") || "");
                    var b = B.pretty(B.get("hotkey_toggle") || "");
                    var parts = [];
                    if (B.get("hotkey_hold")) parts.push(a);
                    if (B.get("hotkey_toggle")) parts.push(b);
                    return parts.length ? parts.join("\n") : "не назначено";
                }
                font.family: T.mono; font.pixelSize: T.t2xs
                color: (B.get("hotkey_hold") || B.get("hotkey_toggle"))
                       ? T.textSecondary : T.danger
                lineHeight: 1.5
            }
        }
    }

    // ---------- содержимое ----------
    Flickable {
        id: scroll
        anchors { left: side.right; right: parent.right; top: parent.top
                  bottom: footerBar.top; rightMargin: 0 }
        clip: true
        contentHeight: content.implicitHeight + 52
        boundsBehavior: Flickable.StopAtBounds

        // Колонка содержимого - не шире 760 и прижата влево, к панели.
        //
        // Было 640 по центру, и на окне в 1060 это давало справа пустую полосу
        // в полтора пальца - владелец её и заметил. Полоса читается как
        // недогрузившаяся страница, а не как поля: слева от колонки стоит
        // панель, справа - ничего.
        //
        // 760 читаемости не стоит: длинная строка вредит сплошному тексту, а
        // здесь его нет - страница набрана рядами, где подпись короче 60 знаков
        // (docs/texts-2026-07-19.md), а справа от неё контрол. Зато на 760
        // встают в строку три метрики «Статистики» и три плашки «Главной», под
        // которые они и свёрстаны.
        Column {
            id: content
            width: Math.min(760, scroll.width - 56)
            x: 28
            y: 26
            spacing: 24

            // Смена страницы: содержимое проявляется и подъезжает на 6 px
            // справа - оттуда, куда ведёт нажатый пункт панели. Раньше страница
            // просто подменялась в кадре, и на широком окне человек не всегда
            // замечал, что вообще куда-то попал.
            //
            // Только вход, без затухания уходящей: 180 на выход плюс 180 на
            // вход - это 360 мс, дольше самого долгого токена, и переключение
            // начинает читаться как загрузка. Уходящая страница исчезает сразу
            // (её показывает `visible`), новая проявляется на её месте.
            //
            // Сдвиг - через Translate, а не через x: x у content занят
            // центрированием колонки по ширине окна, и присвоение сюда порвало
            // бы привязку намертво (тот же капкан, что описан в Metric.qml).
            // Трансформация рисуется поверх раскладки и ей не мешает.
            //
            // 6 px, а не больше: Korti разрешает фейд и НЕБОЛЬШОЙ сдвиг. На 16+
            // текст едет заметно, и глаз ловит движение вместо содержимого.
            transform: Translate { id: pageShift }
            ParallelAnimation {
                id: pageIn
                NumberAnimation { target: content; property: "opacity"
                                  from: 0; to: 1; duration: T.durBase * 1000
                                  easing.type: Easing.Bezier
                                  easing.bezierCurve: T.easeOut }
                NumberAnimation { target: pageShift; property: "x"
                                  from: 6; to: 0; duration: T.durBase * 1000
                                  easing.type: Easing.Bezier
                                  easing.bezierCurve: T.easeOut }
            }

            // Заголовок есть у каждой страницы, и это не украшение: пункт
            // панели стоит СЛЕВА, а не прямо над содержимым, и без заголовка
            // страница начинается неизвестно чем. Когда «Историю» и
            // «Статистику» переключали вкладками сверху, заголовок повторял
            // нажатую вкладку слово в слово и потому был убран; вкладок больше
            // нет, и повторять стало нечего.
            //
            // У «Главной» на его месте приветствие по имени - единственная
            // страница, которая называет не себя, а человека.
            Column {
                width: parent.width
                spacing: 8
                // Сравниваем с РУССКИМ именем страницы, а показываем перевод:
                // имя служит идентификатором, и переводить его в сравнении
                // значит сломать условие на английском языке.
                PageTitle {
                    // Ширина и перенос - из-за приветствия: «Добрый вечер, » с
                    // длинным именем может не поместиться в строку, а Text без
                    // ширины молча вылезает за край.
                    width: parent.width
                    wrapMode: Text.WordWrap
                    text: win.page === "Главная" ? home.greeting : L.t(win.page)
                }
                Text {
                    width: parent.width
                    visible: text !== ""
                    text: L.t(win.subtitles[win.page] || "")
                    wrapMode: Text.WordWrap
                    font.family: T.sans
                    font.pixelSize: T.tMd
                    color: T.textMuted
                }
            }

            // ===== Главная =====
            // Канон Korti (templates/app-shell, Overview): крупный заголовок,
            // ряд карточек-метрик, ниже список последних событий. Здесь то же
            // самое, только события - ваши диктовки.
            //
            // Страница отвечает на три вопроса и больше ни на что: работает?
            // что сделала? сколько всего?
            Column {
                id: home
                visible: win.page === "Главная"
                width: parent.width
                spacing: 16

                property var st: ({})
                property var recent: []
                property string greeting: L.t("Главная")
                // Находки считаются при открытии страницы и после каждого
                // решения: список обязан отвечать на нажатие сразу, иначе
                // человек нажмёт второй раз.
                property var tips: []
                function refreshTips() { home.tips = B.suggestions(); }

                // Последняя диктовка отделена от остальных намеренно. Страница
                // отвечает на «оно работает и что оно только что сделало?», и
                // ответ на вторую половину вопроса - ровно одна запись. В
                // ровном списке из пяти одинаковых строк она ничем не выделялась
                // и читалась пятой по счёту.
                readonly property var last: recent.length ? recent[0] : null
                readonly property var rest: recent.slice(1)

                // Строка состояния: готов ли, чем распознаёт, на чём считает.
                // Спрашиваем приложение (B.statusInfo), а не свой конфиг:
                // модель меняют на «Дополнительно», а грузится она в приложении.
                // Перечитываем на каждый заход на страницу и на каждый changed -
                // этого хватает, чтобы строка не врала, и не требует опроса по
                // таймеру.
                property var status: ({})

                // Чем диктовать. «Зажать» главнее: это основной жест, и мастер
                // первого запуска настраивает именно его. Само сочетание живёт
                // у окна (win.hotkey) - оно нужно ещё «Истории» и «Статистике»;
                // здесь остаётся только то, что нужно одной этой странице.
                property bool holdMode: false

                function reloadStatus() {
                    home.status = B.statusInfo();
                    home.holdMode = !!B.get("hotkey_hold");
                    win.reloadHotkey();
                }

                Connections {
                    target: B
                    function onChanged() { home.reloadStatus() }
                }

                // Первые ~80 знаков - столько помещается в карточку двумя
                // строками. Режем по границе слова: «сводку по прод…» человек
                // дочитывает сам, а «сводку по прода» выглядит как обрыв связи.
                // Порог 50 - чтобы длинное слово без пробелов не съело полстроки.
                function preview(s) {
                    if (!s) return "";
                    if (s.length <= 80) return s;
                    var cut = s.slice(0, 80);
                    var sp = cut.lastIndexOf(" ");
                    return (sp > 50 ? cut.slice(0, sp) : cut) + "…";
                }

                // Есть ли что показывать в числах. Пустые метрики (три «0» и
                // прочерк) - худшее первое впечатление, поэтому до первой
                // диктовки ряда чисел нет вовсе, только зов попробовать.
                readonly property bool hasData: recent.length > 0

                function reload() {
                    // Одним заходом: числа и последние диктовки живут в одном
                    // файле, и читать его дважды незачем.
                    var d = B.homeData();
                    st = d.stats;
                    recent = d.recent;
                    // По имени, а не «Главная».
                    //
                    // Владелец сказал прямо: «Роман, с возвращением» - как в
                    // Wispr; сейчас из Wispr не взято ничего. Имя берём из
                    // учётной записи Windows, спрашивать его отдельным экраном
                    // ради одной строки не стоит. Не узнали - здороваемся без
                    // имени, как раньше: «Доброе утро, » с пустотой на конце
                    // хуже, чем просто «Доброе утро».
                    var h = new Date().getHours();
                    var hi = L.t(h < 5 ? "Доброй ночи" : h < 12 ? "Доброе утро"
                                 : h < 18 ? "Добрый день" : "Добрый вечер");
                    greeting = B.userName ? hi + ", " + B.userName : hi;
                }
                Component.onCompleted: { reload(); refreshTips(); reloadStatus(); }
                // Находки пересчитываем при каждом заходе на страницу: история
                // растёт, пока окно закрыто, и список должен это учитывать.
                onVisibleChanged: if (visible) { reload(); refreshTips(); reloadStatus(); }

                // Предложения обновиться здесь нет, и это не потеря.
                //
                // Пока окон было два, у главного не было панели, и новости о
                // версии оставалось единственное место - верх этой страницы.
                // Панель вернулась, и предложение живёт в её подвале, откуда
                // видно с ЛЮБОЙ страницы, а не только с той, на которую зашли.
                // Две одинаковые новости в одном окне - это не вдвое заметнее,
                // это ошибка вёрстки.

                // Что программа заметила сама. Страница «Слова» была формой,
                // которую надо заполнять руками, - владелец назвал это функцией
                // для айтишника, и был прав. Заполнять её теперь предлагает
                // программа: она видит, что человек повторяет, и приносит
                // ЗНАЧЕНИЕ. Имя даёт человек - назвать по-человечески машина не
                // может, «roman@почта» это «моя почта» или «рабочая», знает
                // только он.
                Repeater {
                    model: home.tips

                    Card {
                        width: home.width
                        Item {
                            width: parent.width
                            implicitHeight: tipCol.implicitHeight + 32

                            Column {
                                id: tipCol
                                anchors { left: parent.left; right: parent.right; top: parent.top
                                          leftMargin: 24; rightMargin: 24; topMargin: 16 }
                                spacing: 12

                                Text {
                                    width: parent.width
                                    wrapMode: Text.WordWrap
                                    text: L.t("Вы диктовали это ") + modelData.times
                                          + (modelData.kind !== "фраза" ? " - " + modelData.kind : "")
                                          + L.t(". Дать короткую фразу?")
                                    font.family: T.sans; font.pixelSize: T.tSm
                                    font.weight: Font.DemiBold; color: T.text
                                }
                                Text {
                                    width: parent.width
                                    wrapMode: Text.WordWrap
                                    maximumLineCount: 3
                                    elide: Text.ElideRight
                                    text: "«" + modelData.value + "»"
                                    font.family: T.sans; font.pixelSize: T.tSm
                                    color: T.textMuted
                                    lineHeight: 1.4
                                }
                                Flow {
                                    width: parent.width
                                    spacing: 8
                                    FlowInput {
                                        id: tipName
                                        // Поле в 180, а не во всю строку: рядом
                                        // помещаются обе кнопки, и решение
                                        // занимает одну строку вместо двух.
                                        // Flow остаётся: если подписи кнопок
                                        // вырастут, ряд перенесётся сам.
                                        width: Math.min(180, parent.width)
                                        placeholder: L.t("как это называть")
                                    }
                                    FlowButton {
                                        label: L.t("Запомнить")
                                        kind: "primary"
                                        onClicked: {
                                            B.acceptSuggestion(tipName.text, modelData.value);
                                            home.refreshTips();
                                        }
                                    }
                                    FlowButton {
                                        label: L.t("Не надо")
                                        onClicked: {
                                            B.declineSuggestion(modelData.value);
                                            home.refreshTips();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Первое, что человек должен узнать: работает ли оно и как им
                // пользоваться. Не «состояние системы», а строка состояния и
                // одна фраза действием.
                Card {
                    width: parent.width
                    Item {
                        width: parent.width
                        implicitHeight: hero.implicitHeight + 32
                        Column {
                            id: hero
                            anchors { left: parent.left; right: parent.right; top: parent.top
                                      leftMargin: 24; rightMargin: 24; topMargin: 16 }
                            spacing: 12

                            // «Готов · Обычная · процессор» - три ответа одной
                            // строкой: работает ли, чем распознаёт, на чём
                            // считает. Устройство раньше было видно только в
                            // журнале, а вопрос «а видеокарту-то оно использует?»
                            // задают первым.
                            //
                            // Точка зелёная, а не акцентная: синий в Korti -
                            // «особенное», а работающая программа - это норма.
                            Row {
                                spacing: 8
                                Rectangle {
                                    width: 8; height: 8; radius: 4
                                    anchors.verticalCenter: parent.verticalCenter
                                    color: home.status.ready ? T.success : T.textMuted
                                }
                                Text {
                                    anchors.verticalCenter: parent.verticalCenter
                                    text: {
                                        if (!home.status.ready)
                                            return L.t("Просыпаюсь…");
                                        // Модель и устройство приходят из
                                        // приложения и до загрузки модели
                                        // пусты. Пустой кусок не показываем:
                                        // «Готов ·  · » хуже, чем «Готов».
                                        var parts = [L.t("Готов")];
                                        if (home.status.model)
                                            parts.push(L.t(home.status.model));
                                        if (home.status.device)
                                            parts.push(L.t(home.status.device));
                                        return parts.join(" · ");
                                    }
                                    font.family: T.sans
                                    font.pixelSize: T.tSm
                                    font.weight: Font.Medium
                                    color: T.textSecondary
                                }
                            }

                            // Сочетание - крупно и плашками, как в мастере
                            // первого запуска. Это главное, что человек сюда
                            // приходит вспомнить, и строчкой в 12 пикселей
                            // посреди абзаца оно не читалось: глаз ищет на
                            // странице форму клавиши, а не слово «Ctrl».
                            KeyCaps {
                                width: hero.width
                                visible: win.hotkey !== ""
                                combo: win.hotkey
                            }

                            Text {
                                width: hero.width
                                wrapMode: Text.WordWrap
                                // Фраза без названия клавиш: их человек уже
                                // прочитал на плашках выше, и повторять
                                // «Зажмите Ctrl + Shift + Space» значит сказать
                                // одно и то же дважды подряд.
                                text: win.hotkey === ""
                                      ? L.t("Сочетание не назначено - задайте его на странице «Диктовка».")
                                      : home.holdMode
                                      ? L.t("Зажмите и говорите. Отпустили - текст на месте.")
                                      : L.t("Нажмите и говорите. Нажмите ещё раз - текст на месте.")
                                font.family: T.sans
                                // 15, а не 17: крупным на карточке теперь
                                // набраны клавиши, и второй крупной строки под
                                // ними быть не должно - они начнут спорить.
                                font.pixelSize: T.tMd
                                font.weight: Font.DemiBold     // 600: заметно, но не «кричит»
                                font.letterSpacing: -0.2
                                color: win.hotkey === "" ? T.danger : T.text
                                lineHeight: 1.3
                            }
                            Text {
                                width: hero.width
                                wrapMode: Text.WordWrap
                                text: L.t("Работает в любом окне: письмо, чат, документ. ")
                                      + L.t("Голос не покидает этот компьютер.")
                                font.family: T.sans
                                font.pixelSize: T.tSm
                                color: T.textMuted
                                lineHeight: 1.5
                            }
                        }
                    }
                }

                // Правка текста не установлена - говорим об этом первым делом
                // и не даём об этом забыть.
                //
                // Раньше она была необязательной, и без неё программа просто
                // работала чуть скромнее. Теперь без неё программа неполна:
                // модель по умолчанию не ставит знаков препинания, не работают
                // ни поправки на ходу, ни преобразования выделенного текста.
                // Молчать про это значит отдать человеку половину программы и
                // не сказать, что вторая половина существует.
                //
                // Плашка - обычный ряд карточки: заголовок и кнопка в одну
                // строку, одна мысль подписью, остальное - под «подробнее».
                // Абзацем она забирала 171 пиксель против нынешних 82, ничего
                // при этом не сообщая сверх. Красной точки нет намеренно:
                // SettingRow красит иконку сам, и подменять его краски ради
                // одной плашки значило бы завести второе мнение о том, как
                // выглядит ряд. Что дело срочное, видно по кнопке - она
                // единственная синяя на странице.
                //
                // ---- Почему состояний три, а не «есть / нет» ----
                //
                // Плашка спрашивала `llmReady()` и на любое «нет» писала «не
                // установлена», а кнопкой предлагала скачать 3.3 ГБ. Для
                // установленной, но уснувшей Ollama это враньё: она лежит на
                // диске, просто не отвечает, - и человек качал бы три
                // гигабайта поверх трёх имеющихся, чтобы получить то же
                // самое. В журнале в этот момент стоит `connection refused`,
                // и это ровно та строка, которую человеку показывать нельзя,
                // а перевести - обязательно.
                //
                // Кнопка при этом одна на все три случая, и это не упрощение:
                // ollama_setup.ensure() сам смотрит, чего не хватает, и делает
                // недостающее - будит сервер, дотягивает модель, ставит с
                // нуля. Меняется только подпись, потому что человеку важно
                // знать, на что он соглашается.
                //
                // «Запустить», а не «Переустановить»: переустановка уснувшую
                // Ollama тоже вылечит, но ценой трёх гигабайт трафика ради
                // того, что чинится запуском сервера за пару секунд.
                Card {
                    width: parent.width
                    visible: !llmBanner.ready
                    SettingRow {
                        first: true
                        icon: ic.sparkles          // тот же знак, что у «Правки текста» в настройках
                        title: llmBanner.status === "sleeping"
                               ? L.t("Правка текста не отвечает")
                               : llmBanner.status === "no_model"
                               ? L.t("Правке текста не хватает модели")
                               : L.t("Правка текста не установлена")
                        // Короче, чем разрешённые 60 знаков, и намеренно:
                        // справа в этой же строке стоит «подробнее», и на
                        // подпись остаётся не вся ширина ряда.
                        // Про знаки препинания тут больше НЕ говорим, и это не
                        // сокращение текста, а исправление вранья. Знаки давно
                        // ставят правила (punct_rules), а самоисправления -
                        // corrections.py; обязательной работы у Ollama не
                        // осталось вовсе. Строка обещала, что без неё не будет
                        // запятых, - и пугала тем, чего не случится.
                        subtitle: llmBanner.status === "sleeping"
                                  ? L.t("Установлена, но сейчас не запущена")
                                  : llmBanner.status === "no_model"
                                  ? L.t("Осталось скачать модель")
                                  : L.t("Нужна для преобразований текста")
                        more: L.t("Без неё не работают преобразования текста и правка ")
                              + L.t("выделенного голосом. Знаки препинания и оговорки ")
                              + L.t("программа чинит сама, без неё. Ставится один раз, ")
                              + L.t("дальше работает без интернета.")
                        FlowButton {
                            label: llmBanner.busy
                                   ? L.t("Ставится…")
                                   : llmBanner.status === "sleeping"
                                   ? L.t("Запустить")
                                   : llmBanner.status === "no_model"
                                   ? L.t("Догрузить")
                                   : L.t("Установить")
                            kind: "primary"
                            enabled: !llmBanner.busy
                            onClicked: { llmBanner.busy = true; B.llmInstall() }
                        }
                    }
                    Item {
                        id: llmBanner
                        property string status: B.llmState()
                        readonly property bool ready: status === "ready"
                        property bool busy: B.llmBusy()
                        Connections {
                            target: B
                            function onChanged() {
                                llmBanner.status = B.llmState();
                                llmBanner.busy = B.llmBusy();
                            }
                            // Конец установки конфиг не трогает, значит onChanged
                            // не придёт: без этого плашка висела бы с кнопкой
                            // «Ставится…» до следующего открытия окна.
                            function onLlmDone(ok) {
                                llmBanner.status = B.llmState();
                                llmBanner.busy = false;
                            }
                        }
                    }
                }

                // Последняя диктовка - крупной карточкой, отдельно от списка.
                //
                // Это вторая половина вопроса, ради которого окно открывают:
                // «работает - и что оно только что сделало?». Ответ на неё
                // лежал первой строкой ровного списка из пяти, то есть выглядел
                // ровно так же, как позавчерашняя фраза: его приходилось искать
                // глазами вместо того, чтобы увидеть.
                //
                // Место - сразу под сочетанием, а не рядом со списком внизу:
                // человек, открывший окно посмотреть надиктованное, не должен
                // сначала прокручивать. Плашка «правка текста не установлена»
                // остаётся выше - она про то, что программа неполна, и это
                // важнее вчерашней фразы.
                //
                // Пусто - не прячем, а зовём попробовать: дырка на её месте
                // выглядит как поломка.
                Card {
                    width: parent.width
                    Item {
                        width: parent.width
                        implicitHeight: lastCol.implicitHeight + 32

                        Column {
                            id: lastCol
                            anchors { left: parent.left; right: parent.right; top: parent.top
                                      leftMargin: 24; rightMargin: 24; topMargin: 16 }
                            spacing: 12

                            Text {
                                width: parent.width
                                wrapMode: Text.WordWrap
                                // Три строки - потолок: обрезано по 80 знакам,
                                // но длинные слова могут дать третью. Дальше
                                // карточка начнёт съедать экран.
                                maximumLineCount: 3
                                elide: Text.ElideRight
                                text: home.last ? home.preview(home.last.text)
                                                : L.t("Надиктуйте первую фразу")
                                font.family: T.sans
                                font.pixelSize: T.tMd
                                font.weight: home.last ? Font.Normal : Font.DemiBold
                                color: T.text
                                lineHeight: 1.4
                            }

                            // Пусто: сочетание строкой, а не плашками, и без
                            // «зажмите» - жест человек прочитал на карточке
                            // прямо над этой. Здесь он узнаёт другое: куда
                            // денется сказанное.
                            Text {
                                visible: !home.last
                                width: parent.width
                                wrapMode: Text.WordWrap
                                text: win.hotkey === ""
                                      ? L.t("Сначала задайте сочетание на странице «Диктовка».")
                                      : win.hotkey + L.t(" - и текст появится здесь.")
                                font.family: T.sans
                                font.pixelSize: T.tSm
                                color: T.textMuted
                                lineHeight: 1.5
                            }

                            // Время и кнопка в одной строке: карточка и так
                            // крупная, а отдельная строка под каждую отправила
                            // бы список за нижний край окна.
                            Item {
                                visible: !!home.last
                                width: parent.width
                                height: copyBtn.height

                                Text {
                                    anchors { left: parent.left; verticalCenter: parent.verticalCenter }
                                    // «2 минуты назад», а не «14:03». На вопрос
                                    // «это то, что я только что сказал?» время
                                    // на часах не отвечает - его ещё надо
                                    // вычесть из текущего.
                                    text: home.last ? B.ago(home.last.ts) : ""
                                    font.family: T.sans
                                    font.pixelSize: T.t2xs
                                    color: T.textMuted
                                }

                                FlowButton {
                                    id: copyBtn
                                    anchors { right: parent.right; verticalCenter: parent.verticalCenter }
                                    label: L.t("Скопировать")
                                    // Копируем целиком, а не обрезанное превью:
                                    // человек забирает свою фразу, а не то, что
                                    // поместилось в карточку.
                                    onClicked: B.copyText(home.last.text)
                                }
                            }
                        }
                    }
                }

                // Числа, а не прилагательные - так говорит система. Первым -
                // сэкономленное время: единственное число, ради которого
                // человек вообще открыл бы эту страницу. До первой диктовки
                // ряда нет: пустые «0» и прочерк выглядят как сломанный экран.
                //
                // Flow, а не Row, хотя на 760 все три и так встают в строку:
                // окно тянется от 940 до любого размера, и на узком краю
                // карточки должны переноситься, а не худеть до нечитаемого.
                // Порог 200 на карточку - при 644 (минимальная ширина колонки)
                // это те же три столбца, при более узком будет два.
                //
                // Верхний предел - три: метрик всего три, и разрешать больше
                // столбцов незачем. Без него растянутое окно раздавало место
                // пустым колонкам, а карточки в нём худели.
                Flow {
                    width: parent.width
                    spacing: 12
                    visible: home.hasData
                    property int cols: Math.max(1, Math.min(3, Math.floor((width + 12) / 200)))
                    // Округляем ВНИЗ, и это не педантизм. При 760 на три
                    // столбца выходит 245.33, Qt округляет ширину карточки
                    // вверх до 246 - и три штуки перестают влезать в строку на
                    // два пикселя: третья метрика уезжала на вторую строку, а
                    // рядом с ней оставалась дыра в полколонки.
                    property real cw: Math.floor((width - (cols - 1) * 12) / cols)
                    Metric {
                        width: parent.cw
                        order: 0
                        label: L.t("сэкономлено")
                        value: home.st.saved_sec || "0 с"
                        hint: L.t("по сравнению с печатью руками")
                    }
                    Metric {
                        width: parent.cw
                        order: 1
                        label: L.t("скорость")
                        pending: !home.st.speedOk
                        value: home.st.speedOk ? home.st.speed
                                               : L.t("Наговорите минуту - посчитаем")
                        hint: L.t("быстрее, чем печатать руками")
                    }
                    Metric {
                        width: parent.cw
                        order: 2
                        label: L.t("надиктовано")
                        // Чистый счётчик слов - его и оживляем: бежит от нуля.
                        countTo: parseInt(home.st.words || "0")
                        hint: L.t("слов за всё время")
                    }
                }

                // Заголовка у списка нет, пока в нём никого: «ПОСЛЕДНЕЕ» над
                // пустотой (одна диктовка - она вся ушла в карточку выше)
                // выглядит как не загрузившийся список.
                SectionHeader { text: L.t("ПОСЛЕДНЕЕ"); visible: home.rest.length > 0 }

                Column {
                    width: parent.width
                    spacing: 8
                    Repeater {
                        // Без первой: она выше, крупной карточкой. Одна и та же
                        // фраза дважды на экране читалась бы как две диктовки.
                        model: home.rest
                        Card {
                            width: home.width
                            Item {
                                width: parent.width
                                implicitHeight: Math.max(52, line.implicitHeight + 26)
                                MouseArea {
                                    id: hit
                                    anchors.fill: parent
                                    hoverEnabled: true
                                    cursorShape: Qt.PointingHandCursor
                                    onClicked: B.copyText(modelData.text)
                                }
                                Rectangle {
                                    id: dot
                                    x: 16
                                    anchors.verticalCenter: parent.verticalCenter
                                    width: 7; height: 7; radius: 3.5
                                    color: T.success
                                }
                                Column {
                                    id: line
                                    anchors { left: dot.right; right: when_.left; top: parent.top
                                              leftMargin: 12; rightMargin: 12; topMargin: 12 }
                                    spacing: 4
                                    Text {
                                        width: parent.width
                                        elide: Text.ElideRight
                                        maximumLineCount: 2
                                        wrapMode: Text.WordWrap
                                        text: modelData.text
                                        font.family: T.sans
                                        font.pixelSize: T.tMd
                                        // Обычный вес, а не полужирный. Это
                                        // содержимое строки, а не её заголовок:
                                        // четыре полужирные фразы подряд
                                        // читались как четыре заголовка.
                                        color: T.text
                                    }
                                    Text {
                                        // Подсказка одна на список, а не по
                                        // штуке на строку: повторённая четыре
                                        // раза, она перестаёт быть подсказкой
                                        // и становится шумом. Показываем под
                                        // курсором - там, где она и нужна.
                                        text: L.t("нажмите, чтобы скопировать")
                                        font.family: T.sans
                                        font.pixelSize: T.t2xs
                                        color: T.textMuted
                                        opacity: hit.containsMouse ? 1 : 0
                                        Behavior on opacity {
                                            NumberAnimation { duration: T.durFast * 1000 }
                                        }
                                    }
                                }
                                Text {
                                    id: when_
                                    anchors { right: parent.right; rightMargin: 16
                                              verticalCenter: parent.verticalCenter }
                                    text: String(modelData.ts).slice(11, 16)
                                    font.family: T.mono
                                    font.pixelSize: T.t2xs
                                    color: T.textMuted
                                }
                            }
                        }
                    }
                }
            }

            // ===== История =====
            Column {
                visible: win.page === "История"
                width: parent.width
                spacing: 12

                // Перечитываем при каждом входе: продиктовал при открытом окне,
                // зашёл сюда - запись уже на месте, без кнопки «Обновить».
                // Сочетание - там же: его показывает пустое состояние списка, и
                // смениться оно могло на «Диктовке», пока страница ждала.
                onVisibleChanged: if (visible) { hist.reload(); win.reloadHotkey() }

                Card {
                    width: parent.width
                    // Главный выключатель первым, его подстройка - следом.
                    // Было наоборот, и получалось два огреха разом: «Забывать
                    // старое» стояло выше «Вести историю», от которого оно
                    // зависит, а разделительная линия рисовалась вплотную к
                    // верхнему краю карточки - flag first: true стоял у второй
                    // строки вместо первой.
                    ToggleRow {
                        first: true
                        title: L.t("Вести историю")
                        subtitle: L.t("Выключите - и программа не будет ничего запоминать")
                        path: "history"
                    }
                    // «Забывать старое» убрано.
                    //
                    // Владелец: «лишнее, если историю и так можно выключить
                    // целиком». Четыре срока хранения - это вопрос, на который
                    // человек не может ответить, потому что не знает, что
                    // выберет через полгода. А выключатель выше отвечает на
                    // тот же страх сразу и без вариантов.
                    //
                    // Чистка по сроку осталась в коде и работает у тех, кто
                    // уже выставил `history_days`: молча забыть чужую настройку
                    // хуже, чем убрать форму.
                }

                // Поиск и обе кнопки одной строкой - как строка поиска в
                // app-shell.
                Row {
                    id: histBar
                    width: parent.width
                    spacing: 8
                    FlowInput {
                        id: histSearch
                        width: histBar.width - histReload.width - histClear.width
                               - 2 * histBar.spacing
                        placeholder: L.t("Найти в надиктованном…")
                        onEdited: (t) => hist.apply(t)
                    }
                    FlowButton { id: histReload; label: L.t("Обновить")
                        onClicked: hist.reload() }
                    FlowButton { id: histClear; label: L.t("Очистить"); kind: "danger"
                        onClicked: { B.clearHistory(); hist.reload() } }
                }
                // Каждая запись - отдельной карточкой, а не строкой в общем
                // списке. Владелец: «всё слиплено, не понимаю как скопировать,
                // не хочу нажимать на строку». Поэтому у карточки внятная
                // структура - дата и время, длительность и число слов, сам
                // текст, - и ЯВНАЯ кнопка «Скопировать». Клик по карточке
                // ничего не копирует: копирует только кнопка.
                //
                // ListView, а не Repeater по всей истории: записей до 400, и
                // рисовать столько карточек разом - лишняя работа. Список держит
                // на экране только видимые, карточки между собой разделяет
                // отбивка по шкале. Виды пустоты - поверх списка: он пуст,
                // ездить нечему.
                Item {
                    width: parent.width
                    height: 430

                    ListView {
                        id: hist
                        anchors.fill: parent
                        clip: true
                        spacing: 12
                        property var all: []
                        property string note: ""
                        function reload() {
                            var d = B.historyData();
                            all = d.rows;
                            note = d.note;
                            apply(histSearch.text);
                        }
                        function apply(q) {
                            q = (q || "").toLowerCase().trim();
                            if (!q) { model = all; return }
                            var out = [];
                            for (var i = 0; i < all.length; i++)
                                if (String(all[i].text).toLowerCase().indexOf(q) !== -1)
                                    out.push(all[i]);
                            model = out;
                        }
                        // Грузит onVisibleChanged страницы, не сборка окна.
                        delegate: Card {
                            width: hist.width
                            // Тень выключена намеренно: карточки лежат в
                            // прокручиваемом списке с клипом, и тень обрезалась
                            // бы по его краю жёсткой кромкой. Волосяной рамки для
                            // «не слиплено» достаточно - её владелец и просил.
                            shadow: false
                            Item {
                                width: parent.width
                                implicitHeight: histCard.implicitHeight + 28
                                Column {
                                    id: histCard
                                    anchors { left: parent.left; right: parent.right
                                              top: parent.top; leftMargin: 20
                                              rightMargin: 20; topMargin: 14 }
                                    spacing: 10
                                    // Дата и время, длительность, число слов -
                                    // готовыми строками из Python (дата словами
                                    // и склонение живут там). Моноширинным: это
                                    // метаданные, голос терминала. «из файла» -
                                    // только у расшифровок, у диктовки с
                                    // микрофона пометки нет.
                                    Text {
                                        width: parent.width
                                        elide: Text.ElideRight
                                        text: modelData.when + "   ·   " + modelData.dur
                                              + "   ·   " + modelData.words
                                              + (modelData.fromFile
                                                 ? "   ·   " + L.t("из файла") : "")
                                        font.family: T.mono; font.pixelSize: T.t2xs
                                        color: T.textMuted
                                    }
                                    Text {
                                        width: parent.width
                                        text: modelData.text
                                        wrapMode: Text.WordWrap
                                        font.family: T.sans; font.pixelSize: T.tMd
                                        color: T.text
                                        lineHeight: 1.35
                                    }
                                    // Кнопкой, а не кликом по карточке: владелец
                                    // не должен гадать, куда нажать. Копируем
                                    // целиком, а не обрезанное.
                                    FlowButton {
                                        label: L.t("Скопировать")
                                        onClicked: B.copyText(modelData.text)
                                    }
                                }
                            }
                        }
                    }

                    // Виды пустоты - поверх ListView. Пока записей ноль, список
                    // пуст, и накладывать на него сообщение можно без опаски.
                    Text {
                        anchors.centerIn: parent
                        visible: hist.count === 0 && histSearch.text !== ""
                        text: L.t("Ничего не нашлось.")
                        font.family: T.sans; font.pixelSize: T.tSm
                        color: T.textFaint
                    }
                    // Пусто и без поиска - зов начать, тот же, что на
                    // «Статистике»: знак, строка про то, что здесь будет,
                    // клавиши и что случится после первой фразы.
                    EmptyState {
                        anchors.top: parent.top
                        visible: hist.count === 0 && histSearch.text === ""
                        icon: ic.history
                        title: L.t("Здесь появится всё, что вы надиктуете")
                        combo: win.hotkey
                        hint: win.hotkey === ""
                              ? L.t("Сначала задайте сочетание на странице «Диктовка».")
                              : L.t("Скажите что-нибудь - каждая фраза ляжет карточкой с кнопкой «Скопировать».")
                        alarm: win.hotkey === ""
                    }
                }
                Note { text: hist.note }
            }

            // ===== Статистика =====
            Column {
                id: statsPage
                visible: win.page === "Статистика"
                width: parent.width
                spacing: 16
                property var s: ({})

                // Страница скрыта при старте (окно открывается на «Главной»):
                // считать статистику при сборке окна незачем, входа хватит.
                onVisibleChanged: if (visible) { s = B.stats(); win.reloadHotkey(); }

                // Пусто - зовём попробовать, а не показываем пять нулей.
                //
                // Так уже сделано на «Главной», и это было верно: шеренга нулей
                // читается как «программа сломана», а не как «вы ещё не
                // начали». Здесь до этого нулей было пять подряд, да ещё и
                // «пока пусто» дважды - в середине графика и подписью под ним.
                //
                // Сочетание - плашками, как на «Главной» и в мастере первого
                // запуска. Строчкой посреди абзаца оно не читалось: глаз ищет
                // на странице форму клавиши, а не слово «Ctrl». А искать его
                // здесь и приходится - это единственная страница, где человеку
                // нечего делать, кроме как пойти и продиктовать.
                //
                // Вёрстка отсюда уехала в EmptyState.qml как есть: этот вид
                // утверждён задачей 6, и остальные пустые страницы теперь
                // повторяют его, а не изобретают каждая свой.
                Card {
                    width: parent.width
                    visible: statsPage.s.hasData === false
                    EmptyState {
                        icon: ic.stats
                        title: L.t("Здесь появятся ваши числа")
                        combo: win.hotkey
                        // Что сделать и что после этого будет считаться.
                        // Пересказывать, что такое «Статистика», не нужно:
                        // человек нажал этот пункт панели сам.
                        hint: win.hotkey === ""
                              ? L.t("Сначала задайте сочетание на странице «Диктовка».")
                              : L.t("Скажите что-нибудь. Счёт слов, времени и дней ")
                                + L.t("подряд пойдёт с первой же диктовки.")
                        alarm: win.hotkey === ""
                    }
                }

                // Три числа крупно - и первыми, до всяких списков.
                //
                // Раньше страница открывалась столбиком из шести одинаковых
                // строк, где «Слов надиктовано 45» стояло ровно так же, как
                // «Печатать это руками - примерно 40 слов в минуту». Похвастаться
                // нечем: чтобы найти главное, приходилось читать всё. Теперь
                // главного ровно три, и оно набрано кеглем, который видно от
                // двери; подробности остались ниже строками.
                //
                // Row, а не Flow: три метрики стоят в строку при любой ширине
                // окна, а Metric с его HorizontalFit сам ужимает длинное
                // «3 ч 20 мин», оставляя «45» крупным.
                Row {
                    width: parent.width
                    spacing: 12
                    visible: statsPage.s.hasData === true
                    property real cw: (width - 2 * spacing) / 3

                    Metric {
                        width: parent.cw
                        order: 0
                        // Значок у подписи - опознавалка метрики с одного
                        // взгляда, как просила задача усилить числа.
                        icon: ic.type
                        label: L.t("слов всего")
                        // Чистый счётчик - его и оживляем: бежит от нуля.
                        countTo: parseInt(statsPage.s.words || "0")
                    }
                    Metric {
                        width: parent.cw
                        order: 1
                        icon: ic.timer
                        label: L.t("сэкономлено")
                        value: statsPage.s.saved_sec || "0 с"
                    }
                    // Серия - дугой, а не голым числом: наглядная доля от
                    // рекорда. Заняла третью клетку метрик, высота подогнана под
                    // соседние (StreakRing.implicitHeight), сетка осталась ровной.
                    StreakRing {
                        width: parent.cw
                        value: statsPage.s.streakDays || 0
                        best: statsPage.s.streakBest || 0
                        label: L.t("дней подряд")
                        record: (statsPage.s.streakBest || 0) > 0
                                ? L.t("рекорд") + " " + statsPage.s.streakBest : ""
                    }
                }

                SectionTitle { text: L.t("По дням"); visible: statsPage.s.hasData === true }
                Card {
                    width: parent.width
                    visible: statsPage.s.hasData === true
                    // Столбцы вырастают лесенкой при заходе на страницу -
                    // тень пересчитывала бы размытие на каждом кадре роста.
                    shadow: false
                    Item {
                        width: parent.width
                        implicitHeight: week.height + 30
                        BarChart {
                            id: week
                            x: 24; y: 16
                            width: parent.width - 48
                            height: 146
                            days: statsPage.s.week || []
                            avg: statsPage.s.weekAvg || 0
                        }
                    }
                    // Рекорд - в той же карточке, а не отдельной: он про те же
                    // столбики, только за всю историю, и разделительной линии
                    // между ними достаточно. Отдельная карточка стоила бы 16
                    // пикселей отступа и лишний заголовок.
                    StatRow {
                        visible: statsPage.s.hasBest === true
                        title: L.t("Лучший день")
                        subtitle: statsPage.s.bestDate || ""
                        value: statsPage.s.bestWords || "-"
                    }
                }

                // «Быстрее печати в N раз» - полосами, а не одной строкой. Видно
                // только когда число честное (набралась минута речи): до этого
                // множитель случаен, и рисовать полосу с потолка нельзя. Само
                // число (userWpm) при этом никуда не делось - оно на полосе.
                SectionTitle { text: L.t("Быстрее печати"); visible: statsPage.s.speedOk === true }
                SpeedBars {
                    width: parent.width
                    visible: statsPage.s.speedOk === true
                    typingWpm: statsPage.s.typingWpm || 40
                    voiceWpm: statsPage.s.userWpm || 0
                    ratio: statsPage.s.speed || ""
                }

                SectionTitle { text: L.t("Итого"); visible: statsPage.s.hasData === true }
                Card {
                    width: parent.width
                    visible: statsPage.s.hasData === true
                    // «Слов надиктовано» и «Дней подряд» отсюда ушли: они
                    // наверху метриками, а строка, повторяющая метрику экраном
                    // ниже, не добавляет ничего, кроме высоты.
                    //
                    // «Сэкономлено» осталось, и это не недосмотр. Метрика
                    // показывает число, а строка отвечает, откуда оно взялось:
                    // сорок слов в минуту - оценка скорости набора, а не замер
                    // конкретного человека. Убрать эту оговорку значит выдать
                    // прикидку за факт, а число экономии - самое лестное на
                    // странице, и врать им дороже всего.
                    StatRow { first: true; title: L.t("Диктовок")
                        subtitle: L.t("Сколько раз вы говорили вместо того, чтобы печатать")
                        value: statsPage.s.dictations || "-" }
                    StatRow { title: L.t("Наговорено"); subtitle: L.t("Столько вы говорили")
                        value: statsPage.s.seconds || "-" }
                    StatRow { title: L.t("Сэкономлено")
                        subtitle: L.t("Печатать это руками - примерно ")
                                  + (statsPage.s.typingWpm || 40)
                                  + L.t(" слов в минуту. Столько вы сберегли")
                        value: statsPage.s.saved_sec || "-" }
                    // «Ваша скорость» строкой отсюда ушла: она теперь полосами
                    // выше («Быстрее печати»), где и число (userWpm на полосе), и
                    // наглядное сравнение с печатью. Строка под ними повторяла бы
                    // число, ничего не добавляя, - тот же довод, что у метрик.
                }

                // ---- Как вы говорите ----
                //
                // Считается по накопленной истории, здесь же, на этой машине.
                // Пока данных мало - раздел не показывается вовсе: сказать
                // «ваше любимое слово - «который»» по трём диктовкам значит
                // соврать с умным видом.
                SectionTitle { text: L.t("Как вы говорите"); visible: ins.d.rows > 0 }
                Card {
                    width: parent.width
                    visible: ins.d.rows > 0
                    Item {
                        id: ins
                        property var d: ({rows: 0})
                        Component.onCompleted: d = B.insights()
                    }
                    Connections {
                        target: statsPage
                        function onVisibleChanged() {
                            if (statsPage.visible) ins.d = B.insights();
                        }
                    }

                    StatRow {
                        first: true
                        visible: ins.d.persona !== ""
                        title: L.t("Ваша манера")
                        subtitle: ins.d.persona || ""
                        value: ""
                    }
                    StatRow {
                        visible: ins.d.top_word !== ""
                        title: L.t("Любимое слово")
                        subtitle: L.t("Чаще всего повторяется в ваших диктовках")
                        value: ins.d.top_word + " · " + ins.d.top_word_n
                    }
                    StatRow {
                        visible: ins.d.phrase !== ""
                        title: L.t("Присказка")
                        subtitle: L.t("Три слова подряд, которые вы говорите чаще прочих")
                        value: ins.d.phrase
                    }
                    StatRow {
                        visible: ins.d.hourText !== ""
                        title: L.t("Часы пик")
                        subtitle: L.t("Когда вы диктуете больше всего")
                        value: ins.d.hourText
                    }
                    // Было «Программа исправила: 10». Владелец спросил, что ему
                    // с этим числом делать, - и вопрос справедлив: число само
                    // по себе не значит ничего. Десять исправлений это много
                    // или мало? Хорошо это или плохо? Ответа не было.
                    //
                    // Теперь строка отвечает на «что делать»: если ниже есть
                    // слова, которые путаются, - вот они, с кнопкой. Если нет,
                    // число значит «всё в порядке, чинить нечего».
                    StatRow {
                        visible: ins.d.fixed > 0
                        title: L.t("Программа исправила")
                        subtitle: (ins.d.pairs || []).length > 0
                            ? L.t("Столько слов она поправила за вас. Что путается чаще - ниже")
                            : L.t("Столько слов она поправила за вас. Ничего чинить не нужно")
                        value: ins.d.fixed + ""
                    }
                    // Слово, которое путается чаще прочих, - и кнопка, чтобы
                    // научить программу за одно нажатие. Открывать «Слова» и
                    // вспоминать написание не нужно: мы его уже знаем.
                    Repeater {
                        model: (ins.d.pairs || []).slice(0, 3)
                        SettingRow {
                            title: L.t("Путается «") + modelData.heard + "»"
                            subtitle: L.t("Вы диктуете «") + modelData.fixed + L.t("», а слышится ")
                                      + L.t("иначе. Уже ") + modelData.n + L.t(" раз")
                            FlowButton {
                                label: L.t("Научить")
                                onClicked: B.addToDictionary(modelData.heard,
                                                             modelData.fixed)
                            }
                        }
                    }
                    // Пока не набралось - говорим сколько ещё, а не молчим.
                    StatRow {
                        visible: !ins.d.enough
                        title: L.t("Пока считаем")
                        subtitle: L.t("Про любимое слово и присказку скажем, когда ")
                                  + L.t("наберётся побольше диктовок")
                        value: ins.d.words + " слов"
                    }
                }

                SectionTitle { text: L.t("Куда диктуете"); visible: (ins.d.where || []).length > 0 }
                Card {
                    width: parent.width
                    visible: (ins.d.where || []).length > 0
                    Repeater {
                        model: ins.d.where || []
                        StatRow {
                            first: index === 0
                            title: modelData.kind
                            subtitle: modelData.words + L.t(" слов за ")
                                      + modelData.count + " диктовок"
                            value: modelData.share + "%"
                        }
                    }
                }
            }

            // ===== Диктовка =====
            // Бывшие Основное + Распознавание + Ввод: одна дверь вместо трёх.
            // Порядок секций - от того, что трогают чаще, к тому, что один раз.
            //
            // Внутри секции ряды разложены по карточкам, 2-4 штуки в каждой:
            // карточка - это группа по смыслу, а не забор вокруг всей
            // страницы.
            //
            // Отступ между карточками - 28, вдвое от внутреннего отступа
            // карточки (14 сверху и снизу ряда). Меньше нельзя: расстояние
            // между рядами ВНУТРИ карточки и так 28, и с зазором 12 группы
            // читались слабее, чем строки в них, - то есть группировки не было
            // видно вовсе. Между секциями - 40 (28 колонки плюс topPadding
            // заголовка), и по этой разнице глаз читает вложенность: без
            // добавочных линий и без второго кегля заголовка.
            Column {
                visible: win.page === "Диктовка"
                width: parent.width
                spacing: 32

                SectionTitle { topPadding: 12; text: L.t("Сочетания") }
                // Сначала два главных жеста: ими диктуют.
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.keyboard
                        title: L.t("Удерживать и говорить")
                        subtitle: L.t("Самый простой способ. Можно назначить и боковую кнопку мыши")
                        HotkeyField { field: "hotkey_hold" }
                    }
                    SettingRow {
                        icon: ic.record
                        title: L.t("Нажать и говорить")
                        subtitle: L.t("Для долгой диктовки, руки свободны")
                        more: L.t("Esc отменяет начатую запись")
                        HotkeyField { field: "hotkey_toggle"; allowClear: true }
                    }
                }
                // Две строки, про которые владелец сказал «непонятно, что
                // это и через что работает; если через Ollama - почему она
                // тогда не требуется». Обе беды были в подписи:
                //
                //   1) она объясняла ЖЕСТ, но не результат. «Зажмите и
                //      скажите» - это как, а человек спрашивал что;
                //   2) про зависимость говорилось только когда правка
                //      выключена. Включил - строчка исчезала, и связь между
                //      «Правкой текста» и этими двумя пропадала совсем.
                //
                // Теперь обе подписи начинаются с результата, а про
                // зависимость говорят ВМЕСТО описания, а не в довесок к
                // нему: подпись - одна мысль до 60 знаков
                // (docs/texts-2026-07-19.md). Пока правка не включена,
                // единственная нужная мысль - что её надо включить. Полное
                // объяснение никуда не делось - оно под «подробнее».
                //
                // Своей карточкой: оба сочетания работают не с диктовкой, а
                // с уже написанным текстом, и оба требуют правки текста.
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.edit
                        title: L.t("Править выделенное голосом")
                        // Привязка к самому тумблеру, а не к B.get: тумблер
                        // теперь на этой же странице, и подпись обязана
                        // меняться сразу, как его щёлкнули (B.get - слот без
                        // сигнала, он бы застыл на старом значении).
                        subtitle: llmToggle.value
                            ? L.t("Выделили, зажали, сказали - текст переписался")
                            : L.t("Сначала включите «Правку текста на ходу» ниже")
                        more: L.t("Работает через правку текста на ходу; ")
                              + L.t("если она выключена, сочетание молчит")
                        HotkeyField { field: "hotkey_command"; allowClear: true }
                    }
                    SettingRow {
                        icon: ic.list
                        title: L.t("Преобразовать текст")
                        subtitle: llmToggle.value
                            ? L.t("Список готовых правок, выбор цифрой")
                            : L.t("Сначала включите «Правку текста на ходу» ниже")
                        more: L.t("Короче, строже, списком, задание для ИИ. ")
                              + L.t("Свои - на странице «Слова»")
                        HotkeyField { field: "hotkey_transform"; allowClear: true }
                    }
                }
                // Остальные два: окно и отмена. Ни то ни другое не про речь.
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.notes
                        title: L.t("Открыть заметки")
                        subtitle: L.t("Отдельное окно для длинной диктовки")
                        more: L.t("Открывается ещё из значка в трее и из главного окна")
                        HotkeyField { field: "hotkey_notes"; allowClear: true }
                    }
                    SettingRow {
                        icon: ic.undo
                        title: L.t("Отменить последнюю диктовку")
                        subtitle: L.t("Стирает вставленное одним нажатием")
                        more: L.t("Не сработает, если вы после вставки что-то напечатали: ")
                              + L.t("иначе Backspace съел бы ваш текст")
                        HotkeyField { field: "undo_hotkey"; allowClear: true }
                    }
                }
                // Своей карточкой - и это ровно та группировка по смыслу, ради
                // которой карточки и заведены. Оба сочетания про одно: текст
                // едет НЕ в активное окно. Диктовка та же самая, конвейер тот
                // же самый (app._process, dest), меняется только последний шаг.
                //
                // Обычная диктовка целится в поле под курсором и в двух случаях
                // до него не достаёт: окно запущено от администратора (наши
                // нажатия туда не пускает сама Windows) и полноэкранная игра.
                // Раньше это был тупик - текст распознан, отдать некуда. Теперь
                // на каждый случай есть жест, которым человек решает заранее.
                //
                // Путь к файлу стоит ТРЕТЬИМ рядом, а не отдельной карточкой:
                // подпись «Диктовать в файл» ссылается на него словами «в файл
                // ниже», и между ссылкой и целью не должно быть ни заголовка,
                // ни зазора в 28 - иначе «ниже» перестаёт значить «вот тут».
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.clipboard
                        title: L.t("Диктовать в буфер")
                        subtitle: L.t("Текст не вставится - вставите его сами")
                        more: L.t("Для окон, куда вставка не проходит: программа от ")
                              + L.t("администратора, игра во весь экран")
                        HotkeyField { field: "hotkey_clipboard"; allowClear: true }
                    }
                    SettingRow {
                        icon: ic.file
                        title: L.t("Диктовать в файл")
                        subtitle: L.t("Мысль на ходу упадёт в конец файла")
                        more: L.t("Не вставляется никуда: запись со временем дописывается ")
                              + L.t("в файл ниже")
                        HotkeyField { field: "hotkey_inbox"; allowClear: true }
                    }
                    SettingRow {
                        icon: ic.notes
                        title: L.t("Файл для диктовки")
                        subtitle: L.t("Куда писать. Пусто - диктовка в файл выключена")
                        more: L.t("Обычный .md или .txt: Обсидиан и Блокнот увидят запись сразу")
                        // Поле И кнопка, а не одно поле. Программу ставят людям,
                        // которые просто пишут письма: путь вида
                        // C:\Users\...\заметки.md они не наберут по памяти и не
                        // должны - для этого есть системный диалог, который они
                        // видели тысячу раз. Поле остаётся для тех, кому проще
                        // вставить путь из буфера.
                        Row {
                            spacing: 8
                            FlowInput {
                                id: inboxPath
                                width: 220
                                text: B.get("inbox_path") || ""
                                onEdited: (t) => B.set("inbox_path", t)
                            }
                            FlowButton {
                                label: L.t("Выбрать…")
                                onClicked: {
                                    var p = B.pickInboxPath();
                                    if (p) inboxPath.text = p;
                                }
                            }
                        }
                    }
                }

                SectionTitle { topPadding: 12; text: L.t("Микрофон") }
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.mic
                        title: L.t("Микрофон")
                        subtitle: L.t("Какой микрофон слушать")
                        Select {
                            options: B.micOptions
                            value: B.get("mic_device")
                            onPicked: (v) => B.set("mic_device", v)
                        }
                    }
                    ToggleRow {
                        icon: ic.history
                        title: L.t("Не терять первое слово")
                        subtitle: L.t("Микрофон наготове, поэтому начало фразы не обрежется")
                        path: "keep_mic_open"
                    }
                    // Разбор на ходу стоит здесь, а не под своим заголовком
                    // «Распознавание»: два ползунка и выбор модели уехали в
                    // «Дополнительно», и в разделе осталась бы одна эта строка.
                    // Заголовок над одной строкой - заголовок ради заголовка,
                    // ровно так уже расформировали «Систему». А по смыслу это
                    // про то, что происходит, пока вы говорите, - то есть сюда.
                    ToggleRow {
                        icon: ic.zap
                        title: L.t("Разбирать речь на ходу")
                        subtitle: L.t("Работает, пока вы говорите - ждать не надо")
                        more: L.t("Поэтому ожидание не зависит от длины: пятнадцать минут ")
                              + L.t("готовы почти так же быстро, как полминуты")
                        path: "stream_asr"
                    }
                    // Два ползунка - «Слышать начало заранее» и «Не реагировать
                    // на случайные касания» - уехали в «Дополнительно». Оба про
                    // десятые доли секунды и оба уже настроены верно; ползунок
                    // наугад - это способ сломать себе диктовку и не понять,
                    // чем (docs/revision-2026-07-19.md, раздел 1).
                }

                SectionTitle { topPadding: 12; text: L.t("Чистка текста") }
                Card {
                    width: parent.width
                    // Выключателей здесь было пять, стало два.
                    //
                    // «Убирать слова-паразиты» и «Слышать вопрос» убраны
                    // намеренно: владелец спросил «зачем выключатель, это же
                    // должно работать всегда» - и он прав. Обе чистки нельзя
                    // заметить как вмешательство: они не переписывают сказанное,
                    // а убирают запинку и ставят знак, который вы и произнесли.
                    // Выключатель у такого - это вопрос «хотите ли вы, чтобы
                    // программа работала хорошо».
                    //
                    // Выключить их по-прежнему можно, и одним движением:
                    // «Насколько править» → «слегка» снимает чистку от бубнежа,
                    // «ничего» - всё сразу. Один понятный переключатель вместо
                    // трёх непонятных.
                    ToggleRow {
                        first: true
                        icon: ic.enter
                        title: L.t("Голосовые команды")
                        subtitle: L.t("«С новой строки», «нажми энтер» - вслух")
                        // Третий кусок - про дату и время. Точка с пробелом между
                        // кусками стоит отдельной строкой, а не внутри перевода:
                        // знак препинания одинаков в обоих языках, и тащить его
                        // в словарь значило бы заводить два ключа, отличающихся
                        // одной точкой.
                        more: L.t("Команда в конце фразы отправляет сообщение и работает ")
                              + L.t("в любой программе") + ". "
                              + L.t("Ещё «сегодняшняя дата» и «текущее время» вставят их в текст")
                        path: "voice_commands"
                    }
                    // Была ДВА раза: здесь как «Понимать поправки на ходу» и
                    // ниже как «Правка текста на ходу» с кнопкой установки.
                    // Владелец сказал прямо: написано дважды про одно и то же.
                    // Осталась одна строка - с примером, состоянием и кнопкой.
                    // Подпись одна на оба состояния: что правка нужна ещё и
                    // сочетаниям, видно по самим сочетаниям выше, а что её надо
                    // доустановить - по строке с кнопкой ниже. Повторять это
                    // здесь значило растить подпись до трёх мыслей.
                    ToggleRow {
                        id: llmToggle
                        icon: ic.sparkles
                        title: L.t("Правка текста на ходу")
                        subtitle: L.t("Сказали «в пятницу, нет, в субботу» - останется суббота")
                        path: "llm.enabled"
                    }

                    // Установка одной кнопкой - та же, что в мастере первого
                    // запуска, и с тем же объяснением. Раньше здесь стояло
                    // «Нужна Ollama» и всё: ни ссылки, ни того, какую модель
                    // качать, ни слова про сервер. Владелец сказал прямо, что
                    // даже он не знает, как это сделать, - значит функции не
                    // существовало, сколько бы кода за ней ни стояло.
                    //
                    // Строка не исчезает после установки: человеку нужно
                    // видеть, что всё на месте, а не догадываться по отсутствию
                    // кнопки. Состояние показывает цвет - зелёный «скачано»,
                    // синий «качается», красный «не скачано или не вышло».
                    SettingRow {
                        id: llmSetup

                        // Не «готово / не готово», а четыре состояния из
                        // ollama_setup.state(). Разница видна на одном случае:
                        // Ollama установлена, но сервер молчит. Раньше строка
                        // говорила «не скачано» и предлагала кнопку на 3.3 ГБ -
                        // то есть звала скачать то, что уже лежит на диске.
                        // В журнале в этот момент `connection refused`, и
                        // показывать эту строку человеку нельзя, а перевести
                        // её на человеческий - обязательно.
                        property string status: B.llmState()
                        readonly property bool ready: status === "ready"
                        property bool busy: B.llmBusy()
                        property bool failed: false
                        property string stage: ""
                        // Последний этап установки. Держим отдельно от `stage`:
                        // тот обнуляется на следующем нажатии, а причина отказа
                        // должна дожить до того, как человек её прочитает.
                        property string lastFail: ""
                        property real frac: 0
                        property real total: 0

                        readonly property color tone: ready ? T.success
                                                    : busy  ? T.accent
                                                            : T.danger
                        readonly property string word: ready ? L.t("скачано")
                                                     : busy  ? (stage || L.t("качается"))
                                                     : failed ? L.t("не вышло")
                                                     : status === "sleeping" ? L.t("не отвечает")
                                                     : status === "no_model" ? L.t("без модели")
                                                     : L.t("не скачано")

                        // Отказы приезжают из ollama_setup строчными - там они
                        // работают ещё и этапами. В подписи это предложение, и
                        // начинаться оно обязано с большой (тот же приём, что
                        // у пробы видеокарты ниже).
                        function cap(s) {
                            return s === "" ? "" : s.charAt(0).toUpperCase() + s.slice(1)
                        }

                        // Заголовок пустой намеренно: строкой выше уже стоит
                        // «Правка текста на ходу», и повторять его здесь -
                        // ровно та претензия, из-за которой две строки слились
                        // в одну. Здесь только состояние и кнопка к ней.
                        title: ""
                        icon: ic.download
                        subtitle: ready
                            ? L.t("Всё установлено. Поправки, тон и преобразования работают")
                            : busy
                            ? (total > 0
                               ? Math.round(frac * 100) + "% из " + (total / 1e9).toFixed(1) + " ГБ"
                               : L.t("идёт установка, диктовке это не мешает"))
                            : failed
                            ? (lastFail !== ""
                               ? cap(lastFail)
                               : L.t("Диктовка работает и без этого - попробуйте ещё раз"))
                            : status === "sleeping"
                            ? L.t("Установлена, но сейчас не запущена - запустим за вас")
                            : status === "no_model"
                            ? L.t("Ollama на месте, осталась модель - 1.9 ГБ")
                            : L.t("Скачаем Ollama и модель - 3.3 ГБ, всё останется здесь")

                        // Всё в один Row, и это не вкусовщина: holder в
                        // SettingRow кладёт детей друг на друга, без раскладки.
                        // Когда полоса и надпись были отдельными детьми, они
                        // налезали одна на другую - видно только на снимке.
                        Row {
                            spacing: 12
                            anchors.verticalCenter: parent.verticalCenter

                            // Полоса - только пока качается, и той же краской,
                            // что точка: одно состояние одним цветом.
                            Rectangle {
                                visible: llmSetup.busy
                                anchors.verticalCenter: parent.verticalCenter
                                width: 130; height: 6; radius: 3; color: T.fill
                                Rectangle {
                                    width: parent.width * Math.max(0, Math.min(1, llmSetup.frac))
                                    height: parent.height; radius: 3; color: T.accent
                                    Behavior on width {
                                        NumberAnimation { duration: T.durBase * 1000
                                                          easing.type: Easing.Bezier
                                                          easing.bezierCurve: T.easeOut }
                                    }
                                }
                            }

                            // Значок состояния: точка цветом плюс слово. Одной
                            // точки мало - цвет читают не все и не всегда, а
                            // «скачано» однозначно.
                            Row {
                                spacing: 8
                                anchors.verticalCenter: parent.verticalCenter
                                Rectangle {
                                    anchors.verticalCenter: parent.verticalCenter
                                    width: 8; height: 8; radius: 4
                                    color: llmSetup.tone
                                    Behavior on color {
                                        ColorAnimation { duration: T.durBase * 1000 }
                                    }
                                    // Пока качается - пульс: неподвижная точка
                                    // не отличается от готовой, а ждать минуты.
                                    // 900 мс и синус - ВНЕ трёх токенов, как у
                                    // точки записи в оверлее: токены меряют
                                    // переход, а это дыхание в ожидании, и темп
                                    // у него свой. Тот же срок, что там, -
                                    // ожидание в программе выглядит одинаково.
                                    SequentialAnimation on opacity {
                                        running: llmSetup.busy; loops: Animation.Infinite
                                        NumberAnimation { from: 0.4; to: 1; duration: 900
                                                          easing.type: Easing.InOutSine }
                                        NumberAnimation { from: 1; to: 0.4; duration: 900
                                                          easing.type: Easing.InOutSine }
                                    }
                                }
                                Text {
                                    anchors.verticalCenter: parent.verticalCenter
                                    text: llmSetup.word
                                    font.family: T.sans; font.pixelSize: T.tSm
                                    font.weight: Font.Medium
                                    color: llmSetup.tone
                                }
                            }

                            FlowButton {
                                anchors.verticalCenter: parent.verticalCenter
                                visible: !llmSetup.busy && !llmSetup.ready
                                // Кнопка одна на все случаи, меняется подпись:
                                // ensure() сам смотрит, чего не хватает, и
                                // доделывает недостающее. «Запустить», а не
                                // «Переустановить», - переустановка уснувшую
                                // Ollama тоже вылечит, но ценой трёх гигабайт
                                // ради того, что чинится запуском сервера.
                                label: llmSetup.failed ? L.t("Ещё раз")
                                     : llmSetup.status === "sleeping" ? L.t("Запустить")
                                     : llmSetup.status === "no_model" ? L.t("Догрузить")
                                     : L.t("Установить")
                                kind: "primary"
                                onClicked: {
                                    llmSetup.failed = false;
                                    llmSetup.lastFail = "";
                                    llmSetup.busy = true;
                                    llmSetup.stage = L.t("начинаю");
                                    llmSetup.frac = 0;
                                    llmSetup.total = 0;
                                    B.llmInstall();
                                }
                            }
                        }

                        Connections {
                            target: B
                            function onLlmStage(stage, frac, total) {
                                llmSetup.busy = true;
                                llmSetup.stage = stage;
                                llmSetup.frac = frac;
                                llmSetup.total = total;
                            }
                            function onLlmDone(ok) {
                                llmSetup.busy = false;
                                llmSetup.status = B.llmState();
                                llmSetup.failed = !ok;
                                // Причину отказа берём из последнего этапа: он
                                // и есть объяснение («не удалось скачать -
                                // проверьте интернет»). Иначе человек получил
                                // бы «не вышло» без единой подсказки, что
                                // делать дальше.
                                llmSetup.lastFail = ok ? "" : llmSetup.stage;
                            }
                        }
                    }

                }

                // Адрес и модель - для тех, у кого Ollama своя и настроена
                // не по умолчанию. Показываем только когда полировка
                // включена и установка уже не нужна: настройка выключенного
                // и недоустановленного - это шум.
                //
                // Своей карточкой, а не двумя строками в общей: они появляются
                // и исчезают целым блоком, и разделительная линия между
                // «скачано» и «Адрес Ollama» показывала бы связь, которой нет.
                Card {
                    width: parent.width
                    visible: llmToggle.value && llmSetup.ready
                    SettingRow {
                        first: true
                        icon: ic.link
                        title: L.t("Адрес Ollama")
                        FlowInput {
                            width: 220
                            text: B.get("llm.url") || ""
                            onEdited: (t) => B.set("llm.url", t)
                        }
                    }
                    SettingRow {
                        icon: ic.box
                        title: L.t("Модель Ollama")
                        subtitle: L.t("Оставьте пусто - найдём подходящую сами")
                        FlowInput {
                            width: 220
                            text: B.get("llm.model") || ""
                            onEdited: (t) => B.set("llm.model", t)
                        }
                    }
                }

                SectionTitle { topPadding: 12; text: L.t("Вставка") }
                // Первая карточка - про то, как текст попадает в чужое окно.
                //
                // «Как вставлять текст» уехало в «Дополнительно» и зовётся
                // там по симптому: «Текст не появляется?». Выбор между
                // «сразу целиком» и «по одной букве» человек не может
                // сделать заранее - он делает его, когда текст не дошёл.
                //
                // «Освобождать память» убрано: владелец сказал «не нужно», и
                // это правда настройка ради настройки. Умолчание было
                // «держать всегда», то есть строка ничего не делала у всех,
                // кто её не трогал; тому, кто диктует, лишние 370 МБ дешевле
                // двух секунд ожидания. Ключ `unload_after_min` остался в
                // конфиге - у кого выставлено, у того и работает.
                Card {
                    width: parent.width
                    ToggleRow {
                        first: true
                        icon: ic.join
                        title: L.t("Продолжать мысль")
                        subtitle: L.t("Вторая фраза приклеится к первой правильно")
                        more: L.t("Пробел спереди и без заглавной посреди предложения. ")
                              + L.t("Не после точки, не в другом окне, не через полчаса")
                        path: "smart_join"
                    }
                    // Было поле, куда вписывали «telegram.exe» через запятую.
                    // Владелец спросил, откуда человеку взять это имя, - и
                    // вопрос был единственно верный: ниоткуда. Теперь список
                    // собирается из запущенных программ, а имя exe остаётся
                    // внутри и наружу не показывается.
                    SettingRow {
                        icon: ic.send
                        title: L.t("Отправлять сообщение")
                        subtitle: L.t("После вставки нажимать Enter - для чатов")
                        more: L.t("Выберите программы из запущенных. Голосовое «нажми энтер» ")
                              + L.t("работает и без этого, везде")
                        Row {
                            spacing: 8
                            Select {
                                id: appPick
                                width: 230
                                options: apps.list
                                value: apps.list.length ? apps.list[0].value : ""
                            }
                            FlowButton {
                                label: L.t("Добавить")
                                enabled: apps.list.length > 0
                                onClicked: B.addAutoEnterApp(appPick.value)
                            }
                        }
                        Item {
                            id: apps
                            property var list: B.runningApps()
                            // Перечитываем по сигналу, а не по таймеру: список
                            // меняется, когда человек что-то запустил, и в этот
                            // момент он не смотрит в наше окно.
                            Connections {
                                target: B
                                function onChanged() { apps.list = B.runningApps() }
                            }
                        }
                    }
                    // Выбранные программы - той же карточкой: это список к
                    // строке выше, а не отдельная настройка.
                    Repeater {
                        model: B.autoEnterApps
                        SettingRow {
                            icon: ic.app
                            title: modelData.label
                            subtitle: modelData.label !== modelData.exe ? modelData.exe : ""
                            FlowButton {
                                label: L.t("Убрать")
                                onClicked: B.removeAutoEnterApp(modelData.exe)
                            }
                        }
                    }
                }

                // Вторая - про то, насколько сильно программа правит сказанное.
                // Три строки об одном, и стоять они должны рядом: человек
                // выбирает не каждую по отдельности, а общую меру вмешательства.
                //
                // «Останавливать музыку» убрано из настроек: владелец
                // сказал «переключателей слишком много», и этот - первый
                // кандидат. Он выключает то, чего человек всё равно не
                // замечает: музыка встаёт на паузу на время фразы и сама
                // возвращается, а если не играла - ничего не происходит.
                // Работает по-прежнему всегда; ключ `pause_music` остался.
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.sliders
                        title: L.t("Насколько править")
                        subtitle: L.t("От «как услышали» до «править моделью»")
                        more: L.t("Ничего - отдать дословно. Слегка - знаки и словарь. ")
                              + L.t("Обычно - плюс убрать бубнёж. Сильно - плюс правка ")
                              + L.t("моделью, но это дольше")
                        Segmented {
                            options: [{label: L.t("ничего"), value: "none"},
                                      {label: L.t("слегка"), value: "light"},
                                      {label: L.t("обычно"), value: "medium"},
                                      {label: L.t("сильно"), value: "high"}]
                            value: B.get("cleanup") || "medium"
                            onPicked: (v) => B.set("cleanup", v)
                        }
                    }
                    // Размер съехал с кнопки в подпись: кнопка - это глагол
                    // («Скачать»), а сколько качать - обстоятельство, и место
                    // ему в тексте под строкой (docs/texts-2026-07-19.md).
                    SettingRow {
                        icon: ic.type
                        title: L.t("Знаки препинания")
                        subtitle: punctBox.ready
                            ? L.t("Ставит запятые по смыслу и слышит вопрос")
                            : L.t("Модель ставит знаки умнее правил - 30 МБ")
                        more: L.t("Правила ставят запятые по списку союзов - мгновенно. ")
                              + L.t("Модель понимает смысл фразы и точнее на сложных, ")
                              + L.t("но её надо скачать: 30 МБ")
                        Row {
                            spacing: 8
                            Segmented {
                                options: [{label: L.t("правила"), value: "rules"},
                                          {label: L.t("модель"), value: "model"}]
                                value: B.get("punctuation") || "rules"
                                enabled: punctBox.ready
                                opacity: enabled ? 1 : 0.45
                                onPicked: (v) => B.set("punctuation", v)
                            }
                            FlowButton {
                                visible: !punctBox.ready
                                label: punctBox.busy ? L.t("Качается…") : L.t("Скачать")
                                enabled: !punctBox.busy
                                onClicked: { punctBox.busy = true; B.punctModelInstall() }
                            }
                        }
                        Item {
                            id: punctBox
                            property bool ready: B.punctModelReady()
                            property bool busy: B.punctBusy()
                            Connections {
                                target: B
                                function onChanged() {
                                    punctBox.ready = B.punctModelReady();
                                    punctBox.busy = B.punctBusy();
                                }
                            }
                        }
                    }
                    // Ответ на «чем давить в вайб-кодинге». Не вставкой в
                    // редактор - вставлять мы и так умеем. Бедой было другое:
                    // модель обучена на обычной речи и пишет «джейсон» словами.
                    SettingRow {
                        icon: ic.code
                        title: L.t("Технические термины")
                        subtitle: L.t("«Джейсон» станет JSON, «гитхаб» - GitHub")
                        more: L.t("Сто терминов разом. Попадут в «Слова» обычными ")
                              + L.t("подстановками - любую можно поправить или убрать")
                        Segmented {
                            options: [{label: L.t("выключены"), value: false},
                                      {label: L.t("включены"), value: true}]
                            value: B.get("tech_terms") || false
                            onPicked: (v) => B.setTechTerms(v)
                        }
                    }
                }

                // Третья - про саму программу, а не про текст.
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.languages
                        title: L.t("Язык интерфейса")
                        subtitle: L.t("Распознавание остаётся русским - меняются только надписи")
                        Segmented {
                            options: [{label: "Русский", value: "ru"},
                                      {label: "English", value: "en"}]
                            value: B.get("ui_language") || "ru"
                            onPicked: (v) => B.set("ui_language", v)
                        }
                    }
                    SettingRow {
                        icon: ic.notes
                        title: L.t("Заметки открываются")
                        // По умолчанию теперь открывается СПИСОК заметок (см.
                        // notes_qt.open) - владелец просил «список, а не пустой
                        // лист». «прошлой»/«новой» оставлены тем, кто диктует В
                        // окно сразу и хочет редактор под фокусом с первой
                        // секунды; список им доступен кнопкой «Назад».
                        subtitle: L.t("Что показать при открытии")
                        Segmented {
                            options: [{label: L.t("списком"), value: "list"},
                                      {label: L.t("прошлой"), value: "last"},
                                      {label: L.t("новой"), value: "new"}]
                            value: B.get("notes_open") || "list"
                            onPicked: (v) => B.set("notes_open", v)
                        }
                    }
                    // «Пробел в конце» и «Не трогать скопированное» уехали в
                    // «Дополнительно», в «Мелочи»: обе про вкус, а не про
                    // поломку, и обе уже стоят как надо.
                }

                // Раздела «Распознавание» больше нет. Выбор модели, устройство
                // и список моделей на диске уехали в «Дополнительно» - их
                // трогают, когда распознаётся медленно или неточно, а не «когда
                // настраивают». Разбор на ходу переехал в «Микрофон», см. там.

                SectionTitle { topPadding: 12; text: L.t("Вид") }
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.palette
                        title: L.t("Оформление")
                        subtitle: L.t("«Система» - как в Windows")
                        Segmented {
                            options: B.themeOptions
                            value: B.get("theme")
                            onPicked: (v) => B.set("theme", v)
                        }
                    }
                    SettingRow {
                        icon: ic.pill
                        title: L.t("Полоска во время записи")
                        subtitle: L.t("Волна внизу экрана, пока вы говорите")
                        more: L.t("Можно поставить сверху или убрать совсем. ")
                              + L.t("Перетаскивается мышью, двойной клик возвращает на место")
                        Segmented {
                            options: B.pillOptions
                            value: B.get("overlay_position")
                            onPicked: (v) => B.set("overlay_position", v)
                        }
                    }
                    // «Фон под настройками» и «Звуковые сигналы» уехали в
                    // «Дополнительно», в «Мелочи»: их выбирают один раз и по
                    // вкусу, а не тогда, когда настраивают диктовку.
                }
            }

            // ===== Дополнительно =====
            // Страница симптомов, а не свалка тумблеров. Каждый заголовок здесь
            // задаёт вопрос, с которым сюда приходят: «Текст не появляется?»,
            // «Записывает само?». Настройка под вопросом - это ответ.
            //
            // Отсюда и порядок: сначала то, что чинят, потом «Мелочи» - то, что
            // меняют по вкусу и что поломкой не бывает.
            Column {
                visible: win.page === "Дополнительно"
                width: parent.width
                spacing: 32

                SectionTitle { topPadding: 12; text: L.t("Если что-то не так") }
                // Первая карточка - беды вокруг нажатия и вставки.
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.clipboard
                        title: L.t("Текст не появляется?")
                        subtitle: L.t("По одной букве медленнее, зато доходит куда угодно")
                        more: L.t("Сразу целиком - мгновенно и подходит почти везде. ")
                              + L.t("По одной букве медленнее, зато доходит туда, ")
                              + L.t("куда первое не доходит")
                        Segmented {
                            options: B.insertOptions
                            value: B.get("insert_mode")
                            onPicked: (v) => B.set("insert_mode", v)
                        }
                    }
                    SettingRow {
                        icon: ic.history
                        title: L.t("Первое слово обрезается?")
                        subtitle: L.t("Сдвиньте вправо - микрофон включится раньше нажатия")
                        Slider {
                            from: 0; to: 1.5; stepSize: 0.1
                            value: B.get("pre_buffer_sec")
                            onMoved: (v) => B.set("pre_buffer_sec", v)
                        }
                    }
                    // Признак называем прямо: решает длина нажатия, и ничего
                    // больше. Число не повторяем - его показывает сам ползунок.
                    SettingRow {
                        icon: ic.timer
                        title: L.t("Записывает само?")
                        subtitle: L.t("Решает длина нажатия: короче - промах, а не диктовка")
                        more: L.t("Задели клавишу мимоходом - записи не будет")
                        Slider {
                            from: 0.1; to: 1.5; stepSize: 0.1
                            value: B.get("min_record_sec")
                            onMoved: (v) => B.set("min_record_sec", v)
                        }
                    }
                }

                // Вторая - беды распознавания. Отдельной карточкой, потому что
                // сюда же входит справка «что лежит на диске»: в общей она
                // читалась бы продолжением ползунков про доли секунды.
                Card {
                    width: parent.width
                    // Переключатель, а не список с карточками и кнопками
                    // скачивания. Моделей осталось две, и обе - GigaAM: выбирать
                    // тут нечего, кроме «побыстрее» и «поаккуратнее».
                    SettingRow {
                        first: true
                        icon: ic.target
                        title: L.t("Слова распознаются неточно?")
                        subtitle: L.t("Внимательная аккуратнее с окончаниями и редкими словами")
                        more: L.t("Обычная подходит почти всем. Переключается на ходу: ")
                              + L.t("старая работает, пока грузится новая")
                        Segmented {
                            options: B.modelOptions
                            value: B.get("model")
                            onPicked: (v) => B.setModel(v)
                        }
                    }
                    // Что лежит на диске. Строки отвечают на два вопроса сразу:
                    // сколько места занято и что будет, если переключиться на
                    // вторую модель (скачается 238 МБ, и лучше знать это
                    // заранее, чем в дороге).
                    //
                    // Своим блоком, а не в общем ряду. Вся страница здесь -
                    // вопросы-симптомы: «Текст не появляется?», «Слова
                    // распознаются неточно?». «Обычная - используется · 236 МБ
                    // на диске» стояла между двумя такими вопросами и читалась
                    // как третий - настройка, которую человек должен решить.
                    // Решать тут нечего: это справка к переключателю выше -
                    // что уже скачано и во что обойдётся «Внимательная».
                    // Подзаголовок и отступ слева говорят это раскладкой:
                    // блок продолжает предыдущий ответ, а не начинает свой
                    // вопрос. Верхней линии у него намеренно нет - она
                    // отрезала бы его от строки, к которой он относится.
                    Item {
                        width: parent.width
                        implicitHeight: diskCol.implicitHeight + 24
                        Column {
                            id: diskCol
                            anchors { left: parent.left; right: parent.right
                                      top: parent.top; leftMargin: 24 }
                            spacing: 0
                            SectionTitle {
                                text: L.t("Что лежит на диске")
                                bottomPadding: 4
                            }
                            Repeater {
                                model: modelDisk.rows
                                SettingRow {
                                    // Первой строке линия сверху не нужна:
                                    // её место занял подзаголовок.
                                    first: index === 0
                                    icon: ic.disk
                                    title: modelData.title
                                    subtitle: modelData.active
                                        ? L.t("используется") + " · " + modelData.onDiskMb + " " + L.t("МБ на диске")
                                        : modelData.downloading
                                          ? L.t("качается…")
                                          : modelData.installed
                                            ? L.t("скачана, лежит про запас") + " · " + modelData.onDiskMb + " " + L.t("МБ")
                                            : L.t("не скачана - скачается") + " " + modelData.sizeMb + " " + L.t("МБ при первом включении")
                                    FlowButton {
                                        visible: !modelData.active && !modelData.downloading
                                        label: modelData.installed ? L.t("Удалить") : L.t("Скачать")
                                        onClicked: modelData.installed
                                            ? B.deleteModel(modelData.id)
                                            : B.downloadModel(modelData.id)
                                    }
                                }
                            }
                        }
                    }
                    Item {
                        id: modelDisk
                        property var rows: B.modelsInfo()
                        Connections {
                            target: B
                            function onModelsChanged() { modelDisk.rows = B.modelsInfo() }
                            function onChanged() { modelDisk.rows = B.modelsInfo() }
                        }
                    }
                    SettingRow {
                        icon: ic.gauge
                        title: L.t("Распознавание медленное?")
                        subtitle: L.t("«Авто» выбирает само. Видеокарта быстрее, если есть")
                        Segmented {
                            // id нужен строке ниже: проба видеокарты сама
                            // двигает этот выбор по итогу замера, а `value`
                            // читается разовым вызовом и о правке не узнает.
                            id: devicePick
                            options: B.deviceOptions
                            value: B.get("device")
                            onPicked: (v) => B.setRestart("device", v)
                        }
                    }

                    // Проба видеокарты - продолжение строки выше, а не своя
                    // настройка: там человек ВЫБИРАЕТ, чем считать, здесь
                    // выясняет, есть ли из чего выбирать. Вид взят у установки
                    // Ollama на «Диктовке»: полоса, точка цветом, слово рядом.
                    // Одинаковые по смыслу вещи в программе должны выглядеть
                    // одинаково, а «долгая установка с этапами» здесь уже была.
                    //
                    // Кнопка честно сообщает и о неудаче. Замер решает сам, и
                    // на машине автора он говорит «медленнее» - см. шапку
                    // dml_setup.py. Поэтому «не помогло» здесь такой же
                    // законный итог, как «помогло», и подпись под него
                    // написана заранее, а не оставлена на потом.
                    SettingRow {
                        id: dmlRow

                        property var st: B.dmlState()
                        property bool busy: false
                        property bool done: false
                        property bool ok: false
                        property string fail: ""
                        property string stage: ""
                        property real frac: 0
                        property var res: ({})

                        // Нельзя вовсе (сборка, не Windows) - строка остаётся
                        // объяснением без кнопки. Прятать её нечестно: человек
                        // читал про видеокарту в README и пришёл сюда искать.
                        readonly property bool can: st.why === ""

                        // «Не помогло» - серым, а не красным: это не ошибка, а
                        // ответ на вопрос. Красный остаётся тому, что и вправду
                        // сломалось, - иначе он перестанет что-либо значить.
                        readonly property color tone: !can ? T.textMuted
                                                    : busy ? T.accent
                                                    : done ? (ok ? T.success : T.textMuted)
                                                    : fail !== "" ? T.danger
                                                                  : T.textSecondary
                        // Секунды словами: «0.32 с». Три знака после запятой -
                        // это отчёт, человеку хватает двух.
                        function sec(v) { return v ? v.toFixed(2) + " " + L.t("с") : "?" }
                        // Отказы приезжают из dml_setup строчными: там они
                        // работают ещё и этапами («скачиваю», «ставлю»), а
                        // этапы пишутся с маленькой. В подписи это уже
                        // предложение, и начинаться оно обязано с большой.
                        function cap(s) {
                            return s === "" ? "" : s.charAt(0).toUpperCase() + s.slice(1)
                        }

                        // Молния, а не тот же датчик, что строкой выше: два
                        // одинаковых значка подряд читаются как одна настройка.
                        icon: ic.zap
                        title: L.t("Ускорить на видеокарте")
                        subtitle: !can
                            ? st.why
                            : busy
                            ? (stage || L.t("проверяю"))
                            : fail !== ""
                            ? cap(fail)
                            : done
                            ? (ok
                               ? L.t("Быстрее") + ": " + sec(res.cpu) + " → " + sec(res.gpu)
                                 + ". " + L.t("Перезапустите программу")
                               : L.t("Видеокарта медленнее") + ": " + sec(res.gpu)
                                 + " " + L.t("против") + " " + sec(res.cpu)
                                 + ". " + L.t("Оставил процессор"))
                            : st.active
                            ? L.t("Уже считает видеокарта")
                            // Колесо на диске, а считает всё ещё процессор -
                            // значит человек уже нажимал и не перезапустился.
                            // Окно к этому моменту закрывали, и весь итог
                            // прошлого нажатия пропал вместе с ним; напомнить
                            // про перезапуск больше некому.
                            : st.installed
                            ? L.t("Поставлено. Перезапустите программу")
                            : L.t("Проверим на вашей записи и покажем секунды")

                        // Подробности - под шеврон, как везде на этой странице.
                        // Длинная запись это отдельная история: на ней
                        // видеокарта выигрывает даже когда на короткой
                        // проиграла, и человеку, который диктует помногу, надо
                        // дать этот факт, а не спрятать его за вердиктом.
                        more: done && res.long_gpu
                            ? L.t("На длинной записи видеокарта быстрее: ")
                              + sec(res.long_gpu) + " " + L.t("против") + " "
                              + sec(res.long_cpu) + ". "
                              + L.t("Диктуете помногу - поставьте «видеокарта» строкой выше")
                            : can && !busy
                            ? L.t("Скачаем 26 МБ и подменим часть распознавания. ")
                              + L.t("Замер решит сам: стало медленнее - вернём процессор")
                            : ""

                        Row {
                            spacing: 12
                            anchors.verticalCenter: parent.verticalCenter

                            Rectangle {
                                visible: dmlRow.busy
                                anchors.verticalCenter: parent.verticalCenter
                                width: 130; height: 6; radius: 3; color: T.fill
                                Rectangle {
                                    width: parent.width * Math.max(0, Math.min(1, dmlRow.frac))
                                    height: parent.height; radius: 3; color: T.accent
                                    Behavior on width {
                                        NumberAnimation { duration: T.durBase * 1000
                                                          easing.type: Easing.OutCubic }
                                    }
                                }
                            }

                            Row {
                                spacing: 8
                                visible: dmlRow.busy || dmlRow.done || dmlRow.fail !== ""
                                anchors.verticalCenter: parent.verticalCenter
                                Rectangle {
                                    anchors.verticalCenter: parent.verticalCenter
                                    width: 8; height: 8; radius: 4
                                    color: dmlRow.tone
                                    Behavior on color {
                                        ColorAnimation { duration: T.durBase * 1000 }
                                    }
                                    SequentialAnimation on opacity {
                                        running: dmlRow.busy; loops: Animation.Infinite
                                        NumberAnimation { from: 0.4; to: 1; duration: 900
                                                          easing.type: Easing.InOutSine }
                                        NumberAnimation { from: 1; to: 0.4; duration: 900
                                                          easing.type: Easing.InOutSine }
                                    }
                                }
                                Text {
                                    anchors.verticalCenter: parent.verticalCenter
                                    text: dmlRow.busy ? L.t("меряю")
                                        : dmlRow.fail !== "" ? L.t("не вышло")
                                        : dmlRow.ok ? L.t("быстрее")
                                                    : L.t("не помогло")
                                    font.family: T.sans; font.pixelSize: T.tSm
                                    font.weight: Font.Medium
                                    color: dmlRow.tone
                                }
                            }

                            FlowButton {
                                anchors.verticalCenter: parent.verticalCenter
                                visible: dmlRow.can && !dmlRow.busy
                                // «Проверить», а не «Ускорить»: ускорит или
                                // нет - решает замер, и обещать в подписи то,
                                // чего может не случиться, нельзя.
                                label: (dmlRow.done || dmlRow.fail !== "")
                                       ? L.t("Ещё раз") : L.t("Проверить")
                                kind: "primary"
                                onClicked: {
                                    dmlRow.fail = "";
                                    dmlRow.done = false;
                                    dmlRow.busy = true;
                                    dmlRow.stage = "";
                                    dmlRow.frac = 0;
                                    B.dmlRun();
                                }
                            }
                        }

                        Connections {
                            target: B
                            function onDmlStage(stage, frac) {
                                dmlRow.busy = true;
                                dmlRow.stage = stage;
                                dmlRow.frac = frac;
                            }
                            function onDmlDone(ok, fail, res) {
                                dmlRow.busy = false;
                                dmlRow.ok = ok;
                                dmlRow.fail = fail;
                                dmlRow.res = res;
                                dmlRow.done = fail === "";
                                dmlRow.st = B.dmlState();
                                // Замер сам решает, чем считать, и записывает
                                // это в настройку строкой выше. Без этой
                                // строчки переключатель показывал бы «авто»
                                // после того, как мы прибили «процессор», -
                                // то есть врал бы про собственное состояние.
                                devicePick.value = B.get("device");
                            }
                        }
                    }
                }

                // Мелочи - не симптомы. Их держим отдельной карточкой, чтобы
                // человек, пришедший чинить, не принял их за причину беды.
                SectionTitle { topPadding: 12; text: L.t("Мелочи") }
                Card {
                    width: parent.width
                    ToggleRow {
                        first: true
                        icon: ic.space
                        title: L.t("Пробел в конце")
                        subtitle: L.t("Чтобы следующая фраза не слиплась с этой")
                        path: "append_space"
                    }
                    ToggleRow {
                        icon: ic.copy
                        title: L.t("Не трогать скопированное")
                        subtitle: L.t("Вернём на место то, что вы копировали до диктовки")
                        path: "restore_clipboard"
                    }
                    ToggleRow {
                        icon: ic.sound
                        title: L.t("Звуковые сигналы")
                        subtitle: L.t("Тихий сигнал, когда запись началась и закончилась")
                        path: "sounds"
                    }
                    // Было «Расположение: карточками / строками». Владелец
                    // спросил «расположение ЧЕГО?» и сам же ответил точнее нас:
                    // разница только в фоне у элементов, ничего никуда не
                    // переставляется. Так и называем.
                    SettingRow {
                        icon: ic.surface
                        title: L.t("Фон под настройками")
                        subtitle: L.t("С фоном - карточками, без фона - строками")
                        more: L.t("С фоном настройки лежат карточками, без фона - ")
                              + L.t("строками через линию. Второе плотнее")
                        Segmented {
                            options: [{label: L.t("есть"), value: "cards"},
                                      {label: L.t("нет"), value: "lines"}]
                            value: B.get("layout") || "cards"
                            onPicked: (v) => B.set("layout", v)
                        }
                    }
                }
            }

            // ===== Слова =====
            // Бывшие Словарь + Замены. Словарь Dragon продаёт за 700 долларов -
            // наш виден и объяснён, а не спрятан за термином.
            Column {
                visible: win.page === "Слова"
                width: parent.width
                spacing: 32

                // Перечитываем таблицу при каждом заходе. Ей это нужно ради
                // пустого состояния: оно решается один раз на загрузку
                // (PairTable.empty), иначе схлопывалось бы под курсором прямо
                // во время набора. Заход на страницу - единственный момент,
                // когда человек на неё не печатает. Заодно освежаем готовые
                // заготовки: их могли включить и заполнить в прошлый заход.
                onVisibleChanged: if (visible) { snips.reload(); presetData.rows = B.snippetPresets() }

                SectionTitle { topPadding: 12; text: L.t("Свои слова") }
                // Объяснение - строкой карточки, а не абзацем над ней. Абзац
                // занимал две строки и читался как введение, которое можно
                // пропустить; ряд с «подробнее» отвечает на «что сюда писать»
                // одной строкой, а подробности отдаёт по требованию.
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.dictionary
                        title: L.t("Что сюда писать")
                        subtitle: L.t("Фамилии, названия, термины - по одному на строку")
                        more: L.t("Те слова, которые программа слышит, но пишет ")
                              + L.t("неправильно. Дальше она будет писать их так, ")
                              + L.t("как написали вы.")
                    }
                    Item {
                        width: parent.width
                        height: 300
                        // Та же волосяная линия, что делит ряды: поле - это
                        // вторая часть карточки, а не приклеенный к ней ящик.
                        Rectangle {
                            anchors { left: parent.left; right: parent.right; top: parent.top
                                      leftMargin: 24; rightMargin: 24 }
                            height: 1
                            color: T.borderFlat
                        }
                        Flickable {
                            anchors.fill: parent
                            anchors.margins: 16
                            clip: true
                            contentHeight: dict.implicitHeight
                            TextEdit {
                                id: dict
                                width: parent.width
                                text: B.dictionaryText
                                font.family: T.mono; font.pixelSize: T.tSm
                                color: T.text
                                selectByMouse: true
                                selectionColor: Qt.rgba(T.accent.r, T.accent.g, T.accent.b, 0.30)
                                selectedTextColor: T.text
                                wrapMode: TextEdit.NoWrap
                                onTextChanged: if (activeFocus) B.setDictionary(text)
                            }
                        }

                        // Пустой словарь - это триста пикселей белого поля под
                        // строкой «Фамилии, названия, термины». Отличить его от
                        // не загрузившегося поля нечем, а на свежей установке
                        // он пустой у всех.
                        //
                        // Пропадает не только когда слово вписали, но и как
                        // только в поле встал курсор: человек уже начал, и
                        // приглашение начать поверх его курсора - это помеха.
                        // Мышь через него проходит насквозь (у самого Item
                        // обработчика нет), так что щелчок по пустому полю
                        // по-прежнему ставит туда курсор.
                        EmptyState {
                            anchors { top: parent.top; topMargin: 8 }
                            visible: dict.text.trim() === "" && !dict.activeFocus
                            icon: ic.dictionary
                            title: L.t("Пока ни одного слова")
                            hint: L.t("Впишите фамилию, название или термин - ")
                                  + L.t("по одному на строку. Дальше программа ")
                                  + L.t("будет писать их так же.")
                            actionLabel: L.t("Вписать слово")
                            onAction: dict.forceActiveFocus()
                        }
                    }
                }

                // ---- Готовые подстановки ----
                // Заготовки на частое: включаешь и вписываешь СВОЁ. Слева фраза
                // уже задана, справа пусто - человек заполняет; часть идёт с
                // готовым значением через переменные ({дата} и прочие), их
                // вписывать не надо.
                //
                // Механика - ровно как у техтерминов (B.setTechTerms): включённая
                // заготовка падает в те же snippets, второго хранилища нет.
                // Отличает их список id в snippets_presets_on (как transforms_hidden
                // у преобразований): по нему блок знает, что показать включённым, а
                // таблица «Подстановки» ниже - какие фразы не дублировать. Поэтому
                // заготовки стоят ВЫШЕ пользовательских, отдельным блоком.
                SectionTitle { topPadding: 12; text: L.t("Готовые подстановки") }
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.swap
                        title: L.t("Включите и впишите своё")
                        subtitle: L.t("Частые фразы уже заведены - вам остаётся значение")
                        more: L.t("«Моя почта», «телефон», «подпись» - включите нужное и впишите ")
                              + L.t("один раз. Дальше скажете фразу - вставится ваше. ")
                              + L.t("Заготовки с датой и временем подставят их сами.")
                    }
                    Repeater {
                        model: presetData.rows
                        SettingRow {
                            // Фраза БЕЗ L.t: это текст диктовки, он русский в
                            // любом интерфейсе - как ключи подстановок и словарь.
                            title: modelData.say
                            subtitle: modelData.fill
                                ? (modelData.enabled
                                   ? L.t("Ваше значение - в поле справа")
                                   : L.t("Включите и впишите своё"))
                                : L.t("Вставит: ") + modelData.preview
                            Row {
                                spacing: 12
                                // Поле для своего значения - только у пустых
                                // заготовок и только когда включены: у готовых
                                // (с датой) вписывать нечего, значение уже есть.
                                FlowInput {
                                    visible: modelData.enabled && modelData.fill
                                    anchors.verticalCenter: parent.verticalCenter
                                    width: 190
                                    text: modelData.value
                                    placeholder: L.t("ваше значение")
                                    onEdited: (t) => B.setSnippetPresetValue(modelData.id, t)
                                }
                                Toggle {
                                    anchors.verticalCenter: parent.verticalCenter
                                    value: modelData.enabled
                                    onToggled: (v) => {
                                        B.setSnippetPreset(modelData.id, v);
                                        // Перечитываем список - обновить галку и
                                        // значение; и таблицу ниже, ведь фраза
                                        // могла уехать в неё (выключили заполненную)
                                        // или уйти из неё (включили свою).
                                        presetData.rows = B.snippetPresets();
                                        snips.reload();
                                    }
                                }
                            }
                        }
                    }
                    Item {
                        id: presetData
                        property var rows: B.snippetPresets()
                    }
                }

                // Обёртка ради отбивки сверху: у SectionTitle её даёт
                // topPadding, а SectionHeader - это Item с кнопкой, и такого
                // свойства у него нет. Пустая распорка не годится - колонка
                // добавила бы к ней свой шаг дважды.
                Item {
                    width: parent.width
                    implicitHeight: snipsHdr.height + 12
                    SectionHeader {
                        id: snipsHdr
                        anchors.bottom: parent.bottom
                        text: L.t("Подстановки"); buttonLabel: L.t("Добавить"); buttonKind: "primary"
                        onAction: snips.add()
                    }
                }
                // Пояснение ПЕРЕД таблицей, а не после неё.
                //
                // Владелец сказал: «подстановки выглядят пусто и непонятно;
                // нужно два поля рядом со стрелкой - слева что говорю, справа
                // на что заменить». Поля со стрелкой были и раньше, но увидеть
                // их можно было, только нажав «Добавить»: пустая таблица
                // показывала одну серую строчку, а объяснение лежало ПОД ней,
                // то есть читалось после того, как непонятно уже стало.
                //
                // Пока подстановок нет, объяснение развёрнуто в полное пустое
                // состояние: знак, строка про то, что это, и пример. Как
                // только появилась первая - схлопывается в обычный ряд: место
                // на странице занимает то, что человек уже понял, а понял он
                // это ровно тогда, когда завёл первую подстановку.
                Card {
                    width: parent.width
                    visible: snips.empty
                    EmptyState {
                        icon: ic.swap
                        title: L.t("Подстановок пока нет")
                        hint: L.t("Слева впишите, что говорите, справа - что ")
                              + L.t("вставится. Скажете «моя почта» - появится адрес.")
                    }
                }
                Card {
                    width: parent.width
                    visible: !snips.empty
                    SettingRow {
                        first: true
                        icon: ic.swap
                        title: L.t("Что на что менять")
                        subtitle: L.t("Слева - что вы говорите, справа - что вставится")
                        more: L.t("Скажете «моя почта» - появится адрес. ")
                              + L.t("Пустые строки не сохраняются.")
                    }
                }
                PairTable {
                    id: snips
                    width: parent.width
                    storeKey: "snippets"
                    // Пустая таблица показывает не серую надпись, а живую
                    // строку: два поля и стрелку между ними. Так видно, что
                    // это форма, а не сообщение об ошибке.
                    showBlankRow: true
                    leftPlaceholder: "моя почта"
                    rightPlaceholder: "roman@example.com"
                }
                // Живые подстановки внутри подстановки: «подпись» с {дата}
                // вставит сегодняшнее число, а не слово «дата».
                //
                // Сами имена БЕЗ L.t намеренно. Это не текст интерфейса, а
                // значения, которые человек впишет в правое поле буквально:
                // переведи мы их на английский - и написанное в подсказке
                // перестало бы работать. Плейсхолдеры русские в любом
                // интерфейсе, ровно как русские словарь и текст диктовки.
                Note {
                    text: L.t("В правой части работают: ")
                          + "{дата}, {дата-словами}, {время}, {день-недели}"
                }
                // Предупреждение о пустых строках - отдельной строкой и только
                // когда они есть. В общем пояснении оно висело всегда и росло
                // до второй строки; предупреждению место рядом с бедой.
                Note {
                    visible: snips.blanks > 0
                    text: L.t("Пустых строк:") + " " + snips.blanks
                          + " - " + L.t("они не сохранятся.")
                }
                // «Не надо» на находке запоминается навсегда - иначе программа
                // спрашивала бы одно и то же каждую неделю. Но дверь назад
                // нужна: промах мыши не должен стоить находки, о которой потом
                // не узнаешь. Строки нет, пока отказываться было не от чего.
                Row {
                    visible: B.declinedCount > 0
                    spacing: 12
                    Text {
                        anchors.verticalCenter: parent.verticalCenter
                        text: L.t("Отклонённых находок:") + " " + B.declinedCount
                        font.family: T.sans; font.pixelSize: T.tSm
                        color: T.textMuted
                    }
                    FlowButton {
                        label: L.t("Предложить снова")
                        onClicked: B.clearDeclined()
                    }
                }

                // «Тон под приложение» со страницы убран.
                //
                // Владелец сказал коротко: «никто не будет это заполнять». Он
                // прав, и правота эта устроена так: чтобы правило заработало,
                // надо знать имя exe чужой программы, придумать слово для тона
                // и держать в голове, что всё вместе требует установленной
                // правки текста. Три условия ради того, чтобы письмо вышло
                // построже, - это цена, которую платят единицы.
                //
                // Код `tone_rules` остаётся живым: у кого правила заведены -
                // работают, из резервной копии восстанавливаются. Мы убрали
                // форму, а не возможность.

                // ---- Преобразования ----
                // Список, который открывается по сочетанию «Преобразовать
                // текст». Готовые написали мы, свои пишет человек - и до сих
                // пор мог написать их только в config.json, то есть никак.
                Item {
                    width: parent.width
                    implicitHeight: tfHdr.height + 12
                    SectionHeader {
                        id: tfHdr
                        anchors.bottom: parent.bottom
                        text: L.t("Свои преобразования")
                        buttonLabel: tf.full ? "" : L.t("Добавить")
                        buttonKind: "primary"
                        onAction: tf.add()
                    }
                }
                // Объяснение - до таблицы, по той же причине, что и у
                // подстановок: после неё оно читается, когда непонятно уже
                // стало.
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.sparkles
                        title: L.t("Как этим пользоваться")
                        subtitle: L.t("Выделите текст, нажмите сочетание, выберите нужное")
                        more: L.t("Слева название, справа что сделать: пишите словами, ")
                              + L.t("как объяснили бы человеку. Список выбирают цифрами, ")
                              + L.t("поэтому больше десяти в него не помещается.")
                    }
                }
                TransformTable {
                    id: tf
                    width: parent.width
                }
                Note {
                    visible: tf.full || tf.blanks > 0
                    text: tf.full ? L.t("Больше не поместится: список выбирают цифрами.")
                                  : L.t("Незаполненных строк:") + " " + tf.blanks
                                    + " - " + L.t("они не сохранятся.")
                }

                SectionTitle { topPadding: 12; text: L.t("Готовые преобразования") }
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.list
                        title: L.t("Что показывать в списке")
                        subtitle: L.t("Выключенное просто не показывается в списке")
                        more: L.t("Чтобы не искать своё среди того, чем не пользуетесь. ")
                              + L.t("Сами преобразования никуда не деваются - их можно ")
                              + L.t("вернуть обратно тем же переключателем.")
                    }
                    Repeater {
                        model: presets.rows
                        SettingRow {
                            icon: ic.forTransform(modelData.id)
                            title: L.t(modelData.title)
                            subtitle: L.t(modelData.hint)
                            Toggle {
                                value: modelData.shown
                                onToggled: (v) => B.setTransformShown(modelData.id, v)
                            }
                        }
                    }
                    Item {
                        id: presets
                        property var rows: B.transformPresets()
                    }
                }
            }

            // ===== О программе =====
            Column {
                visible: win.page === "О программе"
                width: parent.width
                spacing: 32

                Card {
                    width: parent.width
                    Item {
                        width: parent.width
                        implicitHeight: aboutHero.implicitHeight + 32
                        Column {
                            id: aboutHero
                            anchors { left: parent.left; right: parent.right; top: parent.top
                                      leftMargin: 24; rightMargin: 24; topMargin: 16 }
                            spacing: 12
                            // Тот же вордмарк, что на панели, только крупнее:
                            // это витрина продукта, а не строка меню.
                            Wordmark { box: 34; nameSize: T.tDisplay }
                            Text {
                                width: aboutHero.width
                                text: L.t("Диктовка, которая работает без интернета.")
                                font.family: T.sans; font.pixelSize: T.tMd
                                font.weight: Font.DemiBold
                                color: T.text
                            }
                        }
                    }
                    // Четыре строки обещания уехали под «подробнее»: витрина
                    // должна читаться за секунду, а доказательство нужно тому,
                    // кто в обещание не поверил. Отрицательная гарантия сильнее
                    // обещания: не «мы защищаем данные», а «уходить им некуда».
                    SettingRow {
                        icon: ic.shield
                        subtitle: L.t("Голос не покидает этот компьютер - ему некуда уходить")
                        more: L.t("Интернет нужен один раз, чтобы скачать модель, и ещё ")
                              + L.t("чтобы проверять обновления. Поэтому диктовка работает ")
                              + L.t("в поезде, на даче и когда интернет упал.")
                    }
                }

                SectionTitle { topPadding: 12; text: L.t("Что важно знать") }
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.history
                        title: L.t("Первые слова не теряются")
                        subtitle: L.t("Микрофон слушает чуть раньше, чем вы нажали клавишу")
                    }
                    SettingRow {
                        icon: ic.shield
                        title: L.t("Ничего не переписывает")
                        subtitle: L.t("Вычёркивает лишнее, но не дописывает")
                        more: L.t("Ни одно слово в тексте не появится само - только ")
                              + L.t("исчезнет то, что вы сказали между делом")
                    }
                    SettingRow {
                        icon: ic.moon
                        title: L.t("Не мешает компьютеру")
                        subtitle: L.t("В покое не тратит ни процессор, ни сеть")
                    }
                }

                // Как обновлялось. Раньше человек видел номер версии и всё:
                // что в ней изменилось и чем она отличается от вчерашней -
                // узнать было неоткуда, а обновлятор предлагал обновиться,
                // не говоря ради чего.
                // Копия личного. Словарь и замены копятся годами, живут в одном
                // файле рядом с программой и не воспроизводятся ничем: снёс
                // Windows - и нет их. Раздел 0.8 плана уже ловил этот риск на
                // самом проекте («работа висит на одном диске»), на данных
                // владельца вывод тот же.
                SectionTitle { topPadding: 12; text: L.t("Свои слова и настройки") }
                Card {
                    width: parent.width
                    SettingRow {
                        first: true
                        icon: ic.download
                        title: L.t("Сохранить в файл")
                        subtitle: L.t("Словарь, подстановки и сочетания - в файл")
                        more: L.t("Пригодится при переустановке и на втором компьютере. ")
                              + L.t("Загрузка добавляет, а не затирает")
                        Row {
                            spacing: 8
                            FlowButton {
                                label: L.t("Сохранить")
                                onClicked: B.exportData(false)
                            }
                            FlowButton {
                                label: L.t("Сохранить с историей")
                                onClicked: B.exportData(true)
                            }
                        }
                    }
                    SettingRow {
                        icon: ic.upload
                        title: L.t("Загрузить из файла")
                        subtitle: L.t("Добавит к тому, что есть - ничего не пропадёт")
                        FlowButton {
                            label: L.t("Загрузить")
                            onClicked: B.importData()
                        }
                    }
                }

                // Записи, которые не удалось распознать. Раздел появляется
                // только когда такие есть: у человека, у которого всё хорошо,
                // он не должен даже мелькать.
                SectionTitle { topPadding: 12; text: L.t("Несохранённые записи"); visible: saved.count > 0 }
                Card {
                    width: parent.width
                    visible: saved.count > 0
                    Column {
                        id: saved
                        width: parent.width
                        property var rows: []
                        property int count: rows.length
                        Component.onCompleted: rows = B.savedRecordings()
                        Connections {
                            target: B
                            function onChanged() { saved.rows = B.savedRecordings() }
                        }

                        SettingRow {
                            first: true
                            icon: ic.file
                            title: L.t("Речь цела")
                            subtitle: L.t("Распознать не вышло, но запись сохранилась")
                            more: L.t("Нажмите «Распознать» - текст попадёт в буфер обмена, ")
                                  + L.t("и его можно вставить куда нужно.")
                        }

                        Repeater {
                            model: saved.rows
                            SettingRow {
                                icon: ic.mic
                                title: modelData.name
                                subtitle: modelData.note
                                Row {
                                    spacing: 8
                                    FlowButton {
                                        label: L.t("Распознать")
                                        kind: "primary"
                                        onClicked: B.redoRecording(modelData.path)
                                    }
                                    FlowButton {
                                        label: L.t("Удалить")
                                        kind: "danger"
                                        onClicked: B.dropRecording(modelData.path)
                                    }
                                }
                            }
                        }
                    }
                }

                SectionTitle { topPadding: 12; text: L.t("Как обновлялось"); visible: history.count > 0 }
                Card {
                    width: parent.width
                    visible: history.count > 0
                    Column {
                        id: history
                        width: parent.width
                        property int count: rel.count
                        Repeater {
                            id: rel
                            model: B.changelog()
                            // Пункты выпуска уехали под «подробнее»: их по
                            // пять-десять на версию, и раскрытая история была
                            // самой длинной стеной текста во всём окне. Строкой
                            // осталось то, ради чего список открывают: номер,
                            // дата и одна фраза о выпуске.
                            SettingRow {
                                first: index === 0
                                title: L.t("Версия ") + modelData.version
                                subtitle: modelData.title
                                // Пункты в CHANGELOG.md пишутся с полужирным
                                // зачином - «**Что изменилось.** дальше
                                // подробности». Без разметки Qt рисует
                                // звёздочки буквально: список версий был усыпан
                                // `**`. Зачин полужирным не украшение - по нему
                                // список просматривают глазами, не читая целиком.
                                moreFormat: Text.MarkdownText
                                more: (modelData.items || [])
                                      .map(function (s) { return "- " + s }).join("\n")

                                Row {
                                    spacing: 8
                                    // «Сейчас у вас» - единственное, ради
                                    // чего этот список открывают дважды.
                                    Rectangle {
                                        visible: modelData.current
                                        anchors.verticalCenter: parent.verticalCenter
                                        width: nowLbl.implicitWidth + 14
                                        height: 18
                                        radius: 9
                                        color: T.fill
                                        Text {
                                            id: nowLbl
                                            anchors.centerIn: parent
                                            text: L.t("сейчас у вас")
                                            font.family: T.sans; font.pixelSize: T.t2xs
                                            color: T.textSecondary
                                        }
                                    }
                                    Text {
                                        anchors.verticalCenter: parent.verticalCenter
                                        text: modelData.date
                                        font.family: T.mono; font.pixelSize: T.t2xs
                                        color: T.textMuted
                                    }
                                }
                            }
                        }
                    }
                }

                // Прежние версии (архив 0.x) - выплывающей панелью. Владелец:
                // «почему не вижу старые версии? добавь выплывающее окно». В
                // CHANGELOG.md весь 0.x схлопнут в строку «1.0» намеренно, а
                // полная история лежит в docs/history-0.x.md и открывается этой
                // кнопкой. Нет файла (старая сборка) - кнопки просто нет.
                FlowButton {
                    visible: win.oldVersionsData.length > 0
                    label: L.t("Прежние версии")
                    onClicked: win.showOldVersions = true
                }

                SectionTitle { topPadding: 12; text: L.t("Служебное") }
                Card {
                    width: parent.width
                    // Сводка - под «подробнее» и моноширинным: это данные для
                    // письма в поддержку, а не настройка. Развёрнутой она
                    // занимала шесть строк на странице, куда заходят за
                    // кнопками под ней.
                    SettingRow {
                        first: true
                        icon: ic.about
                        title: L.t("Что под капотом")
                        subtitle: L.t("Версия, модель, микрофон - одним списком")
                        moreFont: T.mono
                        more: B.about()
                    }
                }
                Row {
                    spacing: 8
                    FlowButton { label: L.t("Папка приложения"); onClicked: B.openFolder() }
                    // Не имена файлов: рядом с «Папка приложения» они читались
                    // как список того, что лежит внутри, а не как кнопки. Куда
                    // они ведут, видно после нажатия - открывается тот же файл.
                    FlowButton { label: L.t("Файл настроек"); onClicked: B.openConfig() }
                    FlowButton { label: L.t("Журнал работы"); onClicked: B.openLog() }
                    FlowButton { label: L.t("Пройти знакомство заново")
                                 onClicked: B.restartOnboarding() }
                }
            }
        }
    }

    // Ряд, а не одна подпись: рядом с красной ошибкой встаёт дверь в журнал.
    // Прокручиваемая область цепляется анкером именно за РЯД, а не за подпись
    // внутри него: anchors умеют цепляться только к родителю и к соседям, и
    // ссылка вглубь чужого ряда рушит раскладку целиком - все страницы
    // настроек оказываются пустыми, а окно выглядит незагрузившимся.
    Row {
        id: footerBar
        anchors { left: side.right; leftMargin: 32; bottom: parent.bottom
                  bottomMargin: 12 }
        spacing: 12

        Text {
            id: footer
            // Красная подпись - это ошибка, и к ней полагается дверь. Полдюжины
            // сообщений здесь заканчиваются словами «смотрите журнал работы», а
            // журнал жил кнопкой на странице «О программе»: совет верный, но
            // выполнить его с текущей страницы было нельзя.
            property bool danger: false

            text: ""
            font.family: T.mono
            font.pixelSize: T.t2xs
            color: T.textMuted
        }

        // Ссылкой, а не кнопкой: подвал - это одна строка в 11 пикселей, и
        // кнопка высотой 30 распирала бы его вдвое. Приём тот же, что у
        // «подробнее» в рядах настроек.
        Text {
            visible: footer.danger && footer.text !== ""
            anchors.verticalCenter: footer.verticalCenter
            text: L.t("журнал работы")
            font.family: T.sans
            font.pixelSize: T.t2xs
            font.weight: Font.Medium
            font.underline: logHit.containsMouse
            color: logHit.pressed ? T.textMuted
                 : logHit.containsMouse ? T.text : T.textSecondary
            Behavior on color { ColorAnimation { duration: T.durFast * 1000 } }
            MouseArea {
                id: logHit
                anchors.fill: parent
                hoverEnabled: true
                cursorShape: Qt.PointingHandCursor
                onClicked: B.openLog()
            }
        }
    }

    // ---------- перетаскивание файла: расшифровать запись (PLAN 11) ----------
    //
    // На ВСЁ окно, а не на отдельную площадку где-то на странице. Человек с
    // голосовым из телеграма тащит его на программу, а не целится в
    // прямоугольник: промахнуться мимо окна нельзя, промахнуться мимо
    // прямоугольника - запросто, и промах выглядел бы как «не работает».
    //
    // Поверх всего (z), иначе площадку перекрывали бы карточки страницы.
    // Пока ничего не тащат, DropArea прозрачна для мыши и не мешает работать.
    DropArea {
        id: drop
        anchors.fill: parent
        z: 100
        keys: ["text/uri-list"]
        onDropped: (e) => {
            if (e.hasUrls && e.urls.length > 0) {
                e.accept();
                B.dropFile(e.urls[0]);
            }
        }
    }

    // Подсказка появляется только на время перетаскивания. Говорит ДЕЙСТВИЕМ и
    // результатом («отпустите - расшифрую»), а не состоянием («перетащите
    // файл»): к моменту, когда её видно, файл уже над окном, и предлагать
    // перетащить его поздно.
    Rectangle {
        anchors.fill: parent
        z: 101
        visible: opacity > 0
        opacity: drop.containsDrag ? 1 : 0
        Behavior on opacity { NumberAnimation { duration: T.durBase * 1000 } }
        color: Qt.rgba(T.bg.r, T.bg.g, T.bg.b, 0.92)

        Rectangle {
            anchors { fill: parent; margins: 24 }
            radius: T.radiusLg
            color: "transparent"
            border.width: 2
            border.color: T.accent
        }

        Column {
            anchors.centerIn: parent
            spacing: 10
            Icon {
                anchors.horizontalCenter: parent.horizontalCenter
                path: ic.file
                size: 32
                color: T.accent
            }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: L.t("Отпустите - расшифрую")
                font.family: T.sans; font.pixelSize: T.tXl
                font.weight: Font.DemiBold
                color: T.text
            }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: L.t("Запись голоса: wav, mp3, ogg, m4a")
                font.family: T.sans; font.pixelSize: T.tSm
                color: T.textMuted
            }
        }
    }

    // Выплывающая панель прежних версий. Поверх всего окна (её z выше подсказки
    // перетаскивания), закрывается по клику мимо, крестику и Esc. Данные - архив
    // 0.x, прочитанный один раз при сборке окна (win.oldVersionsData).
    VersionsDialog {
        open: win.showOldVersions
        versions: win.oldVersionsData
        title: L.t("Прежние версии")
        onClosed: win.showOldVersions = false
    }
}
