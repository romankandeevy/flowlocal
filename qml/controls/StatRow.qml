// Строка статистики: число справа моноширинным.
// Цифры табличные, поэтому соседние строки не пляшут по ширине.

import QtQuick

SettingRow {
    id: r
    property string value: "—"

    // Кегль 17, а не дисплейный 32. Дисплейный в Korti - для витрины метрик,
    // где число одно и оно главное на экране. Здесь пять строк подряд в
    // столбик, и в 32 каждая читалась заголовком: страница «Статистика»
    // превращалась в пять заголовков без текста. Число всё равно самое
    // заметное в строке - оно справа, полужирное и одно.
    Text {
        text: r.value
        font.family: T.sans
        font.pixelSize: T.tXl
        font.weight: Font.DemiBold
        font.letterSpacing: -0.02 * T.tXl
        color: T.text
    }
}
