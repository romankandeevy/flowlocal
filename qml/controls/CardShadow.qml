// Мягкая тень под карточкой окна настроек.
//
// ---- Почему отдельным файлом и через Loader ----
//
// Ровно та же причина, что у PillShadow: `import QtQuick.Effects` тянет
// Qt6QuickEffects.dll, а он грузится не всегда (HANDOFF, грабли PySide6, лечим
// в theme_qt.effects_ok). Стой импорт прямо в Card.qml - его падение уносило бы
// каждую карточку, то есть всё окно целиком, ради украшения. Здесь падает
// только тень, и Loader это переживает молча.
//
// ---- Почему только у статичных карточек ----
//
// Blur пересчитывается каждый кадр по всему прямоугольнику. На карточке,
// которая просто лежит на странице, это одна отрисовка и потом ничего; на
// карточке, которая едет, растёт или мигает, - это полный пересчёт эффекта на
// каждый кадр анимации. Поэтому тень выключена у метрик (они добегают числами
// и всплывают лесенкой), у волны и у графика. Решает не этот файл, а Card:
// свойство `shadow`, по умолчанию выключенное.
//
// ---- Чего здесь намеренно нет ----
//
// Ни shadowEnabled, ни blurEnabled не анимируются и не привязаны к состоянию.
// Переключение любого из них регенерирует шейдер в рантайме, и это видно
// глазом - кадр застревает. Анимировать, если понадобится, можно shadowOpacity:
// она живёт в уже собранном шейдере и стоит ноль.
//
// autoPaddingEnabled: true обязателен - иначе размытие обрезается по границе
// исходника, и вместо тени получается тёмная кромка ровно по краю карточки.

import QtQuick
import QtQuick.Effects

MultiEffect {
    shadowEnabled: true
    autoPaddingEnabled: true
    // Тонированная в акцент, а не чёрная: почему - в шапке theme.py, у
    // SHADOW_TINT.
    shadowColor: T.shadowFar
    // --shadow-lg из системы, ужатая под карточку: смещение вниз на 6,
    // размытие 24. Тень должна намекать, что карточка лежит НА странице, а не
    // висит над ней сантиметром выше.
    shadowVerticalOffset: 6
    shadowBlur: 0.9
    shadowScale: 1.0
    blurMax: 24
}
