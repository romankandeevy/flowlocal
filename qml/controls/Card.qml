// .ins-card: поверхность бумаги, волосяная линия, радиус 12.
//
// В tkinter это был холст с фоном, нарисованным в PIL суперсэмплом x3, потому
// что рамку tk умеет рисовать только прямоугольником - отсюда и известное
// расхождение с Korti («карточки квадратные, а должны быть скруглённые»).
// Здесь это одно слово: radius.
//
// Корень - Item, а не Rectangle, и это вынужденно: тень рисует MultiEffect,
// которому нужна сама карточка ИСТОЧНИКОМ, а эффект внутри собственного
// источника - петля в графе отрисовки. Поэтому видимая часть уехала в
// отдельный `face`, а тень легла рядом с ним, слоем ниже. Снаружи разницы нет:
// на Card никто не ставил ни color, ни radius, ни border - проверено по всем
// сорока вызовам.

import QtQuick

Item {
    id: card
    default property alias content: body.data

    // Две раскладки, один компонент. «Карточки» - канон Korti: бумага,
    // волосяная рамка, радиус 12. «Линии» - то же содержимое без коробки:
    // рамка и фон снимаются, строки разделяются линиями сами (это уже умеет
    // SettingRow). На длинных страницах вроде «Диктовки» рамок набиралось
    // столько, что они спорили с содержимым.
    //
    // Читаем из T, а не из конфига напрямую: токены - один источник правды, и
    // смена раскладки должна перерисовывать окно на лету, как смена темы.
    readonly property bool lines: T.layout === "lines"

    // Тень. Включена по умолчанию - статичных карточек в окне подавляющее
    // большинство, - но выключается там, где содержимое ДВИЖЕТСЯ.
    //
    // Правило не вкусовое, а про цену кадра: размытие пересчитывается по всему
    // прямоугольнику каждый раз, когда источник изменился. Пока карточка просто
    // лежит, это одна отрисовка за жизнь окна. Стоит внутри поехать графике -
    // добегающему числу метрики, растущим столбцам недельного графика - и тот
    // же пересчёт случается на каждом кадре анимации. Отсюда `shadow: false` у
    // метрик и у карточки с графиком; волна и пилюля тени не имеют вовсе.
    //
    // В раскладке «линии» тени нет по определению: там нет и коробки, под
    // которую её класть.
    property bool shadow: true

    implicitHeight: body.implicitHeight

    // Loader, а не MultiEffect напрямую: `import QtQuick.Effects` тянет
    // Qt6QuickEffects.dll, которая грузится не всегда (HANDOFF, грабли
    // PySide6). В отдельном файле её падение уносит только тень; стой импорт
    // здесь - оно унесло бы каждую карточку окна, то есть окно целиком.
    Loader {
        anchors.fill: face
        z: -1
        active: card.shadow && !card.lines && T.effects
        source: "CardShadow.qml"
        onLoaded: item.source = face
    }

    Rectangle {
        id: face
        anchors.fill: parent
        color: card.lines ? "transparent" : T.paper
        radius: card.lines ? 0 : T.radiusLg
        border.width: card.lines ? 0 : 1
        border.color: T.border

        Column {
            id: body
            width: parent.width
            spacing: 0
        }
    }
}
