// Кольцо фокуса - одно на все контролы.
//
// ---- Почему по visualFocus, а не по activeFocus ----
//
// activeFocus истинен и когда в контрол просто ткнули мышью. Кольцо в ответ на
// клик - шум: человек и так знает, куда нажал, он туда смотрел. Кольцо нужно
// ровно в одном случае - когда фокус приехал с клавиатуры и увидеть его больше
// негде. Именно это различие и называется visualFocus.
//
// В QtQuick.Controls оно есть даром, но там оно считается из focusReason,
// которого у голого Item нет, а тащить сюда Templates ради одного свойства -
// это модуль Qt6QuickTemplates2 в сборку и новый способ уронить окно (см. в
// HANDOFF грабли с Qt6QuickEffects.dll). Поэтому различаем сами и локально:
//
//   * мышь нажала на контрол        -> он помнит, что фокус «мышиный»
//   * контрол ПОТЕРЯЛ фокус         -> память сбрасывается
//
// Второй шаг и делает признак честным. Без него «кликнул, ушёл табом, вернулся
// шифт-табом» оставляло бы контрол «мышиным» навсегда. С ним возврат по
// клавиатуре снова зажигает кольцо, а мышиный клик - нет.
//
// Три пикселя наружу, а не внутрь: кольцо внутри съедает поле контрола и
// налезает на текст. Родитель, который клипует детей, обрежет его - таких
// среди контролов нет, а если появится, кольцу нужен будет свой слой.

import QtQuick

Rectangle {
    id: ring

    // Кого обводим. По умолчанию - родителя: так вызов помещается в одну
    // строку, а радиус подхватывается сам.
    property Item target: parent
    property bool on: false
    // Радиус берём у цели, если он у неё есть (Rectangle), иначе считаем от
    // нуля: у Item радиуса нет вовсе, и обращение к нему дало бы undefined.
    property real targetRadius: (target && target.radius !== undefined) ? target.radius : 0

    readonly property int gap: 3

    anchors.fill: target
    anchors.margins: -gap
    radius: targetRadius + gap
    color: "transparent"
    border.width: 2
    // Акцент - ровно его случай по системе: «фокус, ссылки, выделение».
    border.color: T.accent

    opacity: on ? 1 : 0
    // visible по opacity, а не по on: пока кольцо гаснет, оно ещё должно
    // рисоваться, иначе анимация не видна вовсе.
    visible: opacity > 0
    Behavior on opacity { NumberAnimation { duration: T.durFast * 1000
                                            easing.type: Easing.Bezier
                                            easing.bezierCurve: T.easeOut } }
}
