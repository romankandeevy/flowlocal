# Тестовая запись с микрофона.
test.wav
# Превью настроек снимаются с живого приложения, а на нём видны почта из
# «Замен» и расшифровки из «Истории». Скриншот личных данных — те же личные
# данные, только .gitignore на config.json их не ловит. Перегенерировать на
# чистом конфиге — и тогда закоммитить: витрине они нужны.
tools/preview_settings*.png
# Образцы для замера моделей (tools/bench_asr.py): свой голос и свои слова —
# это личное, как и история. Результат замера — тоже: в нём лежат расшифровки.
samples/
tools/bench_asr.json

